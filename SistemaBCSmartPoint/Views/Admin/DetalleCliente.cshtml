@model Sistema_BC_SMART_POINT.Models.Cliente
@{
    ViewData["Title"] = $"Cliente — {Model.Usuario?.Nombres}";
    Layout = "_AdminLayout";
    var iniciales = $"{Model.Usuario?.Nombres?.FirstOrDefault()}{Model.Usuario?.Apellidos?.FirstOrDefault()}";
    var totalComprado = Model.Ventas?.Where(v => v.EstadoPago == "Pagado").Sum(v => v.TotalVenta) ?? 0;
    var totalPedidos = Model.Ventas?.Count ?? 0;
}


<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
    <div>
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:4px;">
            <a href="@Url.Action("Clientes")"
               style="font-size:13px; color:#6b7280; text-decoration:none;">
                ← Clientes
            </a>
            <span style="color:#d1d5db;">/</span>
            <span style="font-size:13px; color:#111827; font-weight:600;">
                @Model.Usuario?.Nombres @Model.Usuario?.Apellidos
            </span>
        </div>
        <h1 style="font-size:22px; font-weight:700; color:#111827; margin:0;">
            Detalle del cliente
        </h1>
    </div>
    <span class="@(Model.Usuario?.Estado == true ? "badge-activo" : "badge-inactivo")"
          style="padding:6px 14px; border-radius:20px; font-size:12px; font-weight:600;
                 @(Model.Usuario?.Estado == true ? "background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0;" : "background:#fef2f2; color:#dc2626; border:1px solid #fecaca;")">
        @(Model.Usuario?.Estado == true ? "Activo" : "Inactivo")
    </span>
</div>

<div class="dc-grid">

    <div>
        <div class="dc-card">

            <div class="dc-perfil">
                <div class="dc-avatar">@iniciales.ToUpper()</div>
                <div class="dc-nombre">@Model.Usuario?.Nombres @Model.Usuario?.Apellidos</div>
                <div class="dc-email">@Model.Usuario?.Email</div>
            </div>

            <div class="dc-metrics">
                <div class="dc-metric">
                    <div class="m-val">@totalPedidos</div>
                    <div class="m-lbl">Pedidos</div>
                </div>
                <div class="dc-metric">
                    <div class="m-val">S/ @totalComprado.ToString("0")</div>
                    <div class="m-lbl">Comprado</div>
                </div>
            </div>

        </div>

        <div class="dc-card">
            <div class="dc-card-header"><h2>Información personal</h2></div>
            <div class="dc-row">
                <span class="lbl">DNI / RUC</span>
                <span class="val">@(string.IsNullOrEmpty(Model.DniRuc) ? "—" : Model.DniRuc)</span>
            </div>
            <div class="dc-row">
                <span class="lbl">Celular</span>
                <span class="val">@Model.Usuario?.Celular</span>
            </div>
            <div class="dc-row">
                <span class="lbl">Nacimiento</span>
                <span class="val">
                    @(Model.FechaNacimiento != default ? Model.FechaNacimiento.ToString("dd/MM/yyyy") : "—")
                </span>
            </div>
            <div class="dc-row">
                <span class="lbl">Registro</span>
                <span class="val">@Model.Usuario?.FechaRegistro.ToString("dd/MM/yyyy")</span>
            </div>
        </div>

        <div class="dc-card">
            <div class="dc-card-header"><h2>Dirección</h2></div>
            <div class="dc-row">
                <span class="lbl">Dirección</span>
                <span class="val">@(string.IsNullOrEmpty(Model.Direccion) ? "—" : Model.Direccion)</span>
            </div>
            <div class="dc-row">
                <span class="lbl">Ciudad</span>
                <span class="val">@(string.IsNullOrEmpty(Model.Ciudad) ? "—" : Model.Ciudad)</span>
            </div>
            <div class="dc-row">
                <span class="lbl">Código postal</span>
                <span class="val">@(string.IsNullOrEmpty(Model.CodigoPostal) ? "—" : Model.CodigoPostal)</span>
            </div>
        </div>
    </div>

    <div>
        <div class="dc-card">
            <div class="dc-card-header"
                 style="display:flex; justify-content:space-between; align-items:center;">
                <h2>Historial de pedidos</h2>
                <span style="font-size:12px; color:#9ca3af;">@totalPedidos pedido(s)</span>
            </div>

            @if (!Model.Ventas!.Any())
            {
                <div style="padding:32px; text-align:center; color:#9ca3af; font-size:14px;">
                    Este cliente aún no ha realizado pedidos.
                </div>
            }
            else
            {
                @foreach (var v in Model.Ventas!.OrderByDescending(v => v.FechaVenta))
                {
                    string bpClass = v.EstadoPago switch
                    {
                        "Pagado" => "bp-pagado",
                        "En verificación" => "bp-verificando",
                        "Rechazado" => "bp-rechazado",
                        _ => "bp-pendiente"
                    };
                    <div class="venta-row">
                        <div>
                            <div class="venta-num">#@v.IdVenta</div>
                            <div class="venta-fecha">
                                @v.FechaVenta.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                        <div class="venta-items">
                            @v.DetallesVenta.Count ítem(s) ·
                            @v.MetodoPago
                        </div>
                        <span class="badge-pago @bpClass">@v.EstadoPago</span>
                        <div class="venta-total">
                            S/ @v.TotalVenta.ToString("0.00")
                        </div>
                    </div>
                }
            }
        </div>
    </div>

</div>

