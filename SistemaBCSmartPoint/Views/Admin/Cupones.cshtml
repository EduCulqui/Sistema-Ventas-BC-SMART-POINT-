@model IEnumerable<Sistema_BC_SMART_POINT.Models.CuponDescuento>
@{
    ViewData["Title"] = "Cupones";
    Layout = "_AdminLayout";
}

<style>
    .badge-cupon {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .cupon-activo {
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
    }

    .cupon-vencido {
        background: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fecaca;
    }

    .cupon-inactivo {
        background: #F5F5F7;
        color: #4A4A4F;
        border: 1px solid #D2D2D7;
    }

    .code-chip {
        font-family: monospace;
        font-size: 0.875rem;
        font-weight: 700;
        background: #F5F5F7;
        padding: 4px 10px;
        border-radius: 6px;
        letter-spacing: .05em;
        color: #1D1D1F;
        border: 1px solid #D2D2D7;
    }

    .pct-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #1A1A1A;
        color: #F5C500;
        font-size: 0.875rem;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 8px;
        min-width: 52px;
    }

    .btn-adm-primary {
        height: 40px;
        padding: 0 22px;
        background: #F5C500;
        color: #111;
        font-weight: 700;
        font-size: 0.875rem;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: background 0.2s;
    }

        .btn-adm-primary:hover {
            background: #FFDA44;
            color: #111;
        }

    .btn-adm-edit {
        height: 36px;
        padding: 0 14px;
        background: #fff;
        color: #1D1D1F;
        font-weight: 600;
        font-size: 0.8rem;
        border: 1px solid #D2D2D7;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        transition: border-color 0.2s;
    }

        .btn-adm-edit:hover {
            border-color: #F5C500;
            color: #1D1D1F;
        }

    .btn-adm-delete {
        height: 36px;
        padding: 0 14px;
        background: #fff;
        color: #b91c1c;
        font-weight: 600;
        font-size: 0.8rem;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
    }

        .btn-adm-delete:hover {
            background: #fff1f2;
            border-color: #b91c1c;
        }

    .adm-card {
        background: #fff;
        border: 1px solid #D2D2D7;
        border-radius: 14px;
        overflow: hidden;
    }

    .adm-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

        .adm-table thead tr {
            background: #F5F5F7;
            border-bottom: 1px solid #D2D2D7;
        }

        .adm-table th {
            padding: 12px 16px;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 700;
            color: #4A4A4F;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .adm-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #F0F0F0;
            color: #1D1D1F;
            vertical-align: middle;
        }

        .adm-table tbody tr:last-child td {
            border-bottom: none;
        }

        .adm-table tbody tr:hover {
            background: #FAFAFA;
        }

    .dias-alerta {
        font-size: 0.75rem;
        color: #b91c1c;
    }

    .dias-normal {
        font-size: 0.75rem;
        color: #6E6E73;
    }
</style>

<div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:24px;">
    <div>
        <h1 style="font-size:22px; font-weight:700; color:#111827; margin:0;">Cupones de descuento</h1>
        <p style="color:#4A4A4F; font-size:0.875rem; margin-top:4px;">
            @ViewBag.TotalActivos activos · @ViewBag.TotalVencidos vencidos
        </p>
    </div>
    <a href="@Url.Action("CrearCupon")" class="btn-adm-primary">+ Nuevo cupón</a>
</div>

<div class="adm-card">
    <table class="adm-table">
        <thead>
            <tr>
                <th>Código</th>
                <th>Descuento</th>
                <th>Válido desde</th>
                <th>Vence</th>
                <th>Usos</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center; padding:40px; color:#4A4A4F;">
                        No hay cupones registrados.
                    </td>
                </tr>
            }
            @{
                string ObtenerBadgeClass(bool estado, bool vencido)
                {
                    if (!estado) return "cupon-inactivo";
                    if (vencido) return "cupon-vencido";
                    return "cupon-activo";
                }

                string ObtenerBadgeText(bool estado, bool vencido)
                {
                    if (!estado) return "Inactivo";
                    if (vencido) return "Vencido";
                    return "Activo";
                }

                string ObtenerDiasTexto(int diasRestantes)
                {
                    if (diasRestantes == 0) return "Vence hoy";
                    if (diasRestantes == 1) return "Vence mañana";
                    return $"{diasRestantes} días restantes";
                }
            }

            @foreach (var c in Model)
            {
                bool vencido = c.FechaVencimiento < DateTime.Today;
                int diasRestantes = (c.FechaVencimiento - DateTime.Today).Days;
                string badgeClass = ObtenerBadgeClass(c.Estado, vencido);
                string badgeText = ObtenerBadgeText(c.Estado, vencido);
                string diasTexto = ObtenerDiasTexto(diasRestantes);

                <tr>
                    <td><span class="code-chip">@c.CodigoCupon</span></td>
                    <td><span class="pct-badge">@c.PorcentajeDescuento%</span></td>
                    <td style="font-size:0.875rem; color:#4A4A4F;">
                        @c.FechaInicio.ToString("dd/MM/yyyy")
                    </td>
                    <td>
                        <div style="font-size:0.875rem; color:#4A4A4F;">
                            @c.FechaVencimiento.ToString("dd/MM/yyyy")
                        </div>
                        @if (!vencido && c.Estado)
                        {
                            <div class="@(diasRestantes <= 7 ? "dias-alerta" : "dias-normal")">
                                @diasTexto
                            </div>
                        }
                    </td>
                    <td style="text-align:center; font-weight:600; color:#1D1D1F;">
                        @(c.Ventas?.Count ?? 0)
                    </td>
                    <td><span class="badge-cupon @badgeClass">@badgeText</span></td>
                    <td>
                        <div style="display:flex; gap:6px;">
                            <a href="@Url.Action("EditarCupon", new { id = c.IdCuponDescuento })"
                               class="btn-adm-edit">Editar</a>
                            <form method="post" asp-action="ToggleEstadoCupon"
                                  onsubmit="return confirm('¿Cambiar estado del cupón @c.CodigoCupon?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.IdCuponDescuento" />
                                <button type="submit"
                                        class="@(c.Estado ? "btn-adm-delete" : "btn-adm-edit")"
                                        style="font-size:0.8rem; padding:0 12px;">
                                    @(c.Estado ? "Desactivar" : "Activar")
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>