@model Sistema_BC_SMART_POINT.Models.Envio
@{
    ViewData["Title"] = $"Gestionar envío #{Model.IdEnvio}";
    Layout = "_AdminLayout";
    int? adminId = ViewBag.AdminId;
}


<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
    <div>
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:4px;">
            <a href="@Url.Action("Envios")"
               style="font-size:13px; color:#6b7280; text-decoration:none;">
                ← Envíos
            </a>
            <span style="color:#d1d5db;">/</span>
            <span style="font-size:13px; color:#111827; font-weight:600;">
                Envío #@Model.IdEnvio
            </span>
        </div>
        <h1 style="font-size:22px; font-weight:700; color:#111827; margin:0;">
            Gestionar envío
        </h1>
    </div>
</div>

<div class="ev-grid">

    <div>
        <div class="ev-card">
            <div class="ev-card-header">
                <h2>Datos del despacho</h2>
            </div>
            <div class="ev-card-body">
                <form method="post" asp-action="EditarEnvio">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="idEnvio" value="@Model.IdEnvio" />
                    <input type="hidden" name="adminId" value="@adminId" />

                    <div class="ev-field">
                        <label>Estado del envío</label>
                        <select name="estadoEnvio">
                            @foreach (var est in new[] { "Preparando", "Despachado", "En camino", "Entregado", "Devuelto" })
                            {
                                <option value="@est" selected="@(Model.EstadoEnvio == est ? "selected" : null)">
                                    @est
                                </option>
                            }
                        </select>
                    </div>

                    <div class="ev-field">
                        <label>Empresa de transporte</label>
                        <input type="text" name="empresaTransporte"
                               value="@Model.EmpresaTransporte"
                               placeholder="Ej: Olva Courier, Shalom, etc." />
                    </div>

                    <div class="ev-field">
                        <label>Número de seguimiento</label>
                        <input type="text" name="numeroSeguimiento"
                               value="@Model.NumeroSeguimiento"
                               placeholder="Ej: OC-123456789" />
                    </div>

                    <div class="ev-grid-2">
                        <div class="ev-field">
                            <label>Fecha de envío</label>
                            <input type="date" name="fechaEnvio"
                                   value="@(Model.FechaEnvio.HasValue? Model.FechaEnvio.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>
                        <div class="ev-field">
                            <label>Entrega estimada</label>
                            <input type="date" name="fechaEntregaEstimada"
                                   value="@(Model.FechaEntregaEstimada.HasValue? Model.FechaEntregaEstimada.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>
                    </div>

                    <button type="submit" class="btn-guardar">
                        Guardar cambios
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div>

        <div class="ev-card" style="margin-bottom:16px;">
            <div class="ev-card-header"><h2>Progreso del envío</h2></div>
            <div class="timeline">
                @{
                    var estados = new[] { "Preparando", "Despachado", "En camino", "Entregado" };
                    int actual = Array.IndexOf(estados, Model.EstadoEnvio);
                }
                @for (int i = 0; i < estados.Length; i++)
                {
                    string stepClass = i < actual ? "done" : i == actual ? "curr" : "";
                    string dot = i < actual ? "✓" : (i + 1).ToString();
                    <div class="tl-step @stepClass">
                        <div class="tl-dot">@dot</div>
                        <div class="tl-label">@estados[i]</div>
                    </div>
                }
            </div>
        </div>


        <div class="ev-card">
            <div class="ev-card-header"><h2>Información del pedido</h2></div>
            <div class="ev-info-row">
                <span class="lbl">Pedido</span>
                <span class="val">#@Model.VentaId</span>
            </div>
            <div class="ev-info-row">
                <span class="lbl">Cliente</span>
                <span class="val">
                    @Model.Venta?.Cliente?.Usuario?.Nombres
                    @Model.Venta?.Cliente?.Usuario?.Apellidos
                </span>
            </div>
            <div class="ev-info-row">
                <span class="lbl">Celular</span>
                <span class="val">@Model.Venta?.Cliente?.Usuario?.Celular</span>
            </div>
            <div class="ev-info-row">
                <span class="lbl">Dirección</span>
                <span class="val" style="text-align:right; max-width:180px;">
                    @Model.DireccionEnvio
                </span>
            </div>
            <div class="ev-info-row">
                <span class="lbl">Ciudad</span>
                <span class="val">@Model.Ciudad</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.CodigoPostal))
            {
                <div class="ev-info-row">
                    <span class="lbl">Código postal</span>
                    <span class="val">@Model.CodigoPostal</span>
                </div>
            }
            <div class="ev-info-row">
                <span class="lbl">Total venta</span>
                <span class="val" style="font-weight:700;">
                    S/ @Model.Venta?.TotalVenta.ToString("0.00")
                </span>
            </div>
        </div>

    </div>
</div>



<style>
    .ev-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 20px;
        align-items: start;
    }

    .ev-card {
        background: #fff;
        border: 1px solid var(--bc-borde);
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 16px;
    }

    .ev-card-header {
        padding: 16px 22px;
        border-bottom: 1px solid #f3f4f6;
    }

        .ev-card-header h2 {
            font-size: 13px;
            font-weight: 600;
            color: #111827;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: .05em;
        }

    .ev-card-body {
        padding: 22px;
    }

    .ev-field {
        margin-bottom: 18px;
    }

        .ev-field:last-child {
            margin-bottom: 0;
        }

        .ev-field label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #374151;
            margin-bottom: 6px;
        }

        .ev-field input,
        .ev-field select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 14px;
            color: #111827;
            outline: none;
            font-family: inherit;
            transition: border-color .15s, box-shadow .15s;
            background: #fff;
        }

            .ev-field input:focus,
            .ev-field select:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 3px rgba(37,99,235,.1);
            }

    .ev-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    /* Info readonly */
    .ev-info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 11px 22px;
        border-bottom: 1px solid #f9fafb;
        font-size: 14px;
    }

        .ev-info-row:last-child {
            border-bottom: none;
        }

        .ev-info-row .lbl {
            color: #6b7280;
        }

        .ev-info-row .val {
            color: #111827;
            font-weight: 500;
            font-size: 13px;
        }

    /* Timeline */
    .timeline {
        padding: 20px 22px;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .tl-step {
        display: flex;
        gap: 14px;
        position: relative;
    }

        .tl-step:not(:last-child)::before {
            content: '';
            position: absolute;
            left: 11px;
            top: 24px;
            bottom: -4px;
            width: 2px;
            background: #e5e7eb;
        }

        .tl-step.done::before {
            background: #bbf7d0;
        }

    .tl-dot {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        border: 2px solid #e5e7eb;
        background: #fff;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        margin-top: 2px;
        z-index: 1;
    }

    .tl-step.done .tl-dot {
        border-color: #16a34a;
        background: #f0fdf4;
        color: #16a34a;
    }

    .tl-step.curr .tl-dot {
        border-color: #2563eb;
        background: #eff6ff;
        color: #2563eb;
    }

    .tl-label {
        font-size: 13px;
        color: #9ca3af;
        padding-bottom: 20px;
        font-weight: 400;
    }

    .tl-step.done .tl-label {
        color: #374151;
        font-weight: 500;
    }

    .tl-step.curr .tl-label {
        color: #1d4ed8;
        font-weight: 600;
    }

    .btn-guardar {
        width: 100%;
        padding: 12px;
        background: var(--bc-negro);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: background .15s;
        margin-top: 4px;
    }

        .btn-guardar:hover {
            background: var(--bc-negro-hover);
        }
</style>