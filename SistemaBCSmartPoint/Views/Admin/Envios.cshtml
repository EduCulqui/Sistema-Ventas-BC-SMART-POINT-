@model IEnumerable<Sistema_BC_SMART_POINT.Models.Envio>
@{
    ViewData["Title"] = "Envíos";
    Layout = "_AdminLayout";
    string? estadoFiltro = ViewBag.EstadoFiltro;
}

<div class="adm-page-header">
    <div>
        <h1>Envíos</h1>
        <p>
            @Model.Count() envíos
            @if (!string.IsNullOrEmpty(estadoFiltro))
            {
                <span>· filtrado por <strong>@estadoFiltro</strong></span>
            }
        </p>
    </div>
</div>

<div class="filtro-tabs">
    <a href="@Url.Action("Envios")"
       class="filtro-tab @(estadoFiltro == null ? "active" : "")">
        Todos
        <span class="count">@(ViewBag.TotalPreparando + ViewBag.TotalDespachado + ViewBag.TotalEnCamino + ViewBag.TotalEntregado)</span>
    </a>
    <a href="@Url.Action("Envios", new { estado = "Preparando" })"
       class="filtro-tab @(estadoFiltro == "Preparando" ? "active" : "")">
        Preparando
        <span class="count">@ViewBag.TotalPreparando</span>
    </a>
    <a href="@Url.Action("Envios", new { estado = "Despachado" })"
       class="filtro-tab @(estadoFiltro == "Despachado" ? "active" : "")">
        Despachado
        <span class="count">@ViewBag.TotalDespachado</span>
    </a>
    <a href="@Url.Action("Envios", new { estado = "En camino" })"
       class="filtro-tab @(estadoFiltro == "En camino" ? "active" : "")">
        En camino
        <span class="count">@ViewBag.TotalEnCamino</span>
    </a>
    <a href="@Url.Action("Envios", new { estado = "Entregado" })"
       class="filtro-tab @(estadoFiltro == "Entregado" ? "active" : "")">
        Entregados
        <span class="count">@ViewBag.TotalEntregado</span>
    </a>
</div>

<div class="adm-card">
    <table class="adm-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Cliente</th>
                <th>Dirección</th>
                <th>Empresa</th>
                <th>Seguimiento</th>
                <th>Fecha envío</th>
                <th>Entrega est.</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="9" class="td-empty">No hay envíos con ese filtro.</td>
                </tr>
            }
            @foreach (var e in Model)
            {
                <tr>
                    <td>
                        <div class="td-id">#@e.IdEnvio</div>
                        <div class="td-sub">Pedido #@e.VentaId</div>
                    </td>
                    <td>
                        <div class="td-nombre">@e.Venta?.Cliente?.Usuario?.Nombres @e.Venta?.Cliente?.Usuario?.Apellidos</div>
                        <div class="td-celular">@e.Venta?.Cliente?.Usuario?.Celular</div>
                    </td>
                    <td>
                        <div class="td-dir">@e.DireccionEnvio</div>
                        <div class="td-ciudad">@e.Ciudad</div>
                    </td>
                    <td class="td-empresa">@(string.IsNullOrEmpty(e.EmpresaTransporte) ? "—" : e.EmpresaTransporte)</td>
                    <td>
                        @if (!string.IsNullOrEmpty(e.NumeroSeguimiento))
                        {
                            <span class="td-seguimiento">@e.NumeroSeguimiento</span>
                        }
                        else
                        {
                            <span class="td-na">Sin asignar</span>
                        }
                    </td>
                    <td class="td-fecha">@(e.FechaEnvio.HasValue? e.FechaEnvio.Value.ToString("dd/MM/yyyy") : "—")</td>
                    <td class="td-fecha">@(e.FechaEntregaEstimada.HasValue? e.FechaEntregaEstimada.Value.ToString("dd/MM/yyyy") : "—")</td>
                    <td>
                        @{
                            string badgeEnvio = e.EstadoEnvio switch
                            {
                                "Despachado" => "badge-despachado",
                                "En camino" => "badge-encamino",
                                "Entregado" => "badge-entregado",
                                "Devuelto" => "badge-devuelto",
                                _ => "badge-preparando"
                            };
                        }
                        <span class="badge-envio @badgeEnvio">@e.EstadoEnvio</span>
                    </td>
                    <td>
                        <a href="@Url.Action("EditarEnvio", new { id = e.IdEnvio })"
                           class="btn-adm-edit">Gestionar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .adm-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--bc-borde);
    }

        .adm-page-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--bc-texto-1);
            margin: 0 0 4px;
            letter-spacing: -0.02em;
        }

        .adm-page-header p {
            font-size: 0.825rem;
            color: var(--bc-texto-2);
            margin: 0;
        }

        .adm-page-header strong {
            color: var(--bc-texto-1);
            font-weight: 600;
        }

    .filtro-tabs {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
    }

    .filtro-tab {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--bc-texto-2);
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 8px;
        padding: 0.4rem 0.85rem;
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s, background 0.15s;
        white-space: nowrap;
    }

        .filtro-tab:hover {
            color: var(--bc-texto-1);
            border-color: var(--bc-texto-2);
        }

        .filtro-tab.active {
            background: var(--bc-negro);
            color: var(--bc-amarillo);
            border-color: var(--bc-negro);
            font-weight: 600;
        }

            .filtro-tab.active .count {
                background: rgba(245, 197, 0, 0.15);
                color: var(--bc-amarillo);
            }

    .count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        background: var(--bc-fondo);
        color: var(--bc-texto-2);
        border-radius: 20px;
        padding: 1px 7px;
        min-width: 22px;
    }

    .adm-card {
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 16px;
        overflow: hidden;
    }

    .adm-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

        .adm-table thead tr {
            background: var(--bc-fondo);
        }

        .adm-table th {
            padding: 0.75rem 1.25rem;
            text-align: left;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--bc-texto-2);
            text-transform: uppercase;
            letter-spacing: 0.07em;
            border-bottom: 1px solid var(--bc-borde);
            white-space: nowrap;
        }

        .adm-table td {
            padding: 0.85rem 1.25rem;
            border-bottom: 1px solid var(--bc-borde);
            color: var(--bc-texto-1);
            vertical-align: middle;
        }

        .adm-table tbody tr:last-child td {
            border-bottom: none;
        }

        .adm-table tbody tr:hover {
            background: var(--bc-fondo);
        }

    .td-empty {
        text-align: center;
        padding: 2.5rem;
        color: var(--bc-texto-2);
        font-size: 0.875rem;
    }

    .td-id {
        font-weight: 700;
        color: var(--bc-texto-1);
        font-size: 0.9rem;
    }

    .td-sub {
        font-size: 0.72rem;
        color: var(--bc-texto-2);
        margin-top: 2px;
        font-weight: 400;
    }

    .td-nombre {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--bc-texto-1);
    }

    .td-celular {
        font-size: 0.72rem;
        color: var(--bc-texto-2);
        margin-top: 2px;
    }

    .td-dir {
        font-size: 0.8rem;
        color: var(--bc-texto-2);
        max-width: 160px;
        line-height: 1.4;
    }

    .td-ciudad {
        font-size: 0.7rem;
        color: var(--bc-texto-2);
    }

    .td-empresa {
        font-size: 0.825rem;
        color: var(--bc-texto-1);
    }

    .td-seguimiento {
        font-family: monospace;
        font-size: 0.75rem;
        background: var(--bc-fondo);
        border: 1px solid var(--bc-borde);
        padding: 3px 8px;
        border-radius: 6px;
        color: var(--bc-texto-1);
        display: inline-block;
    }

    .td-na {
        font-size: 0.75rem;
        color: var(--bc-texto-2);
    }

    .td-fecha {
        font-size: 0.8rem;
        color: var(--bc-texto-2);
        white-space: nowrap;
    }

    .badge-envio {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        letter-spacing: 0.02em;
        white-space: nowrap;
    }

    .badge-preparando {
        background: var(--bc-fondo);
        color: var(--bc-texto-2);
    }

    .badge-despachado {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .badge-encamino {
        background: #fff7ed;
        color: #c2410c;
    }

    .badge-entregado {
        background: #f0fdf4;
        color: #15803d;
    }

    .badge-devuelto {
        background: #fff1f2;
        color: #b91c1c;
    }

    .btn-adm-edit {
        display: inline-flex;
        align-items: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--bc-texto-2);
        background: transparent;
        border: 1px solid var(--bc-borde);
        border-radius: 8px;
        padding: 0.35rem 0.85rem;
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s;
        white-space: nowrap;
    }

        .btn-adm-edit:hover {
            color: var(--bc-texto-1);
            border-color: var(--bc-texto-2);
        }

    @@media (max-width: 700px) {
        .adm-table th, .adm-table td

    {
        padding: 0.65rem 0.75rem;
    }

    }
</style>
