@model Sistema_BC_SMART_POINT.Models.CuponDescuento
@{
    ViewData["Title"] = "Editar cupón";
    Layout = "_AdminLayout";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
    <div>
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:4px;">
            <a href="@Url.Action("Cupones")"
               style="font-size:13px; color:#6b7280; text-decoration:none;">
                ← Cupones
            </a>
            <span style="color:#d1d5db;">/</span>
            <span style="font-size:13px; color:#111827; font-weight:600; font-family:monospace;">
                @Model.CodigoCupon
            </span>
        </div>
        <h1 style="font-size:22px; font-weight:700; color:#111827; margin:0;">Editar cupón</h1>
    </div>
</div>

<div class="adm-form-card" style="max-width:580px;">
    <form method="post" asp-action="EditarCupon">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdCuponDescuento" />
        <input type="hidden" asp-for="FechaCreación" />

        <p style="font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase;
                  letter-spacing:.07em; margin-bottom:20px;">
            Configuración del cupón
        </p>

        <div class="adm-field">
            <label asp-for="CodigoCupon">Código del cupón</label>
            <input asp-for="CodigoCupon"
                   style="font-family:monospace; font-size:15px; letter-spacing:.05em; text-transform:uppercase;" />
            <div class="field-error"><span asp-validation-for="CodigoCupon"></span></div>
        </div>

        <div class="adm-field">
            <label asp-for="PorcentajeDescuento">Porcentaje de descuento (1% — 95%)</label>
            <div style="display:flex; align-items:center; gap:12px;">
                <input asp-for="PorcentajeDescuento"
                       type="number" min="1" max="95" step="1"
                       style="max-width:140px;" />
                <span style="font-size:24px; font-weight:700; color:#111827;">%</span>
            </div>
            <div class="field-error"><span asp-validation-for="PorcentajeDescuento"></span></div>
        </div>

        <div class="adm-form-grid-2">
            <div class="adm-field">
                <label asp-for="FechaInicio">Válido desde</label>
                <input asp-for="FechaInicio" type="date"
                       value="@Model.FechaInicio.ToString("yyyy-MM-dd")" />
                <div class="field-error"><span asp-validation-for="FechaInicio"></span></div>
            </div>
            <div class="adm-field">
                <label asp-for="FechaVencimiento">Vence el</label>
                <input asp-for="FechaVencimiento" type="date"
                       value="@Model.FechaVencimiento.ToString("yyyy-MM-dd")" />
                <div class="field-error"><span asp-validation-for="FechaVencimiento"></span></div>
            </div>
        </div>

        <div class="adm-field">
            <div class="adm-check">
                <input asp-for="Estado" type="checkbox" />
                <label asp-for="Estado">Cupón activo</label>
            </div>
        </div>

        <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:10px;
                    padding:14px 16px; margin-bottom:20px; font-size:13px; color:#6b7280;">
            Creado el @Model.FechaCreación.ToString("dd/MM/yyyy 'a las' HH:mm")
            · Usado en @(Model.Ventas?.Count ?? 0) pedido(s)
        </div>

        <div class="adm-form-footer">
            <button type="submit" class="btn-adm-primary">Guardar cambios</button>
            <a href="@Url.Action("Cupones")" class="btn-adm-edit">Cancelar</a>
        </div>
    </form>
</div>