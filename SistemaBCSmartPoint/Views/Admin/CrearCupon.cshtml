@model Sistema_BC_SMART_POINT.Models.CuponDescuento
@{
    ViewData["Title"] = "Nuevo cupón";
    Layout = "_AdminLayout";
}

<style>
    .adm-form-card {
        background: #fff;
        border: 1px solid #D2D2D7;
        border-radius: 14px;
        padding: 28px 32px;
    }

    .adm-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 20px;
    }

        .adm-field label {
            font-size: 0.875rem;
            font-weight: 600;
            color: #1D1D1F;
        }

        .adm-field input[type="text"],
        .adm-field input[type="number"],
        .adm-field input[type="date"] {
            height: 40px;
            padding: 0 12px;
            border: 1px solid #D2D2D7;
            border-radius: 8px;
            font-size: 0.875rem;
            color: #1D1D1F;
            background: #fff;
            outline: none;
            transition: border-color 0.2s;
            width: 100%;
        }

        .adm-field input:focus {
            border-color: #F5C500;
        }

    .adm-form-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .adm-check {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .adm-check input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: #F5C500;
            cursor: pointer;
        }

        .adm-check label {
            font-size: 0.875rem;
            font-weight: 500;
            color: #1D1D1F;
            cursor: pointer;
        }

    .field-error {
        font-size: 0.78rem;
        color: #b91c1c;
        min-height: 16px;
    }

    .adm-form-footer {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid #D2D2D7;
    }

    .btn-adm-primary {
        height: 40px;
        padding: 0 22px;
        background: #F5C500;
        color: #111;
        font-weight: 700;
        font-size: 0.875rem;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-adm-primary:hover {
            background: #FFDA44;
        }

    .btn-adm-edit {
        height: 40px;
        padding: 0 18px;
        background: #fff;
        color: #1D1D1F;
        font-weight: 600;
        font-size: 0.875rem;
        border: 1px solid #D2D2D7;
        border-radius: 10px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: border-color 0.2s;
    }

        .btn-adm-edit:hover {
            border-color: #F5C500;
            color: #1D1D1F;
        }
</style>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
    <div>
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:4px;">
            <a href="@Url.Action("Cupones")"
               style="font-size:0.875rem; color:#4A4A4F; text-decoration:none;">
                ← Cupones
            </a>
        </div>
        <h1 style="font-size:22px; font-weight:700; color:#111827; margin:0;">Nuevo cupón</h1>
    </div>
</div>

<div class="adm-form-card" style="max-width:580px;">
    <form method="post" asp-action="CrearCupon">
        @Html.AntiForgeryToken()
        <p style="font-size:0.75rem; font-weight:600; color:#4A4A4F; text-transform:uppercase;
                  letter-spacing:.07em; margin-bottom:20px;">
            Configuración del cupón
        </p>
        <div class="adm-field">
            <label asp-for="CodigoCupon">
                Código del cupón
                <span style="font-size:0.75rem; color:#4A4A4F; font-weight:400;">
                    (se guardará en mayúsculas)
                </span>
            </label>
            <input asp-for="CodigoCupon"
                   placeholder="Ej: APPLE10"
                   style="font-family:monospace; font-size:15px; letter-spacing:.05em; text-transform:uppercase;" />
            <div class="field-error"><span asp-validation-for="CodigoCupon"></span></div>
        </div>
        <div class="adm-field">
            <label asp-for="PorcentajeDescuento">
                Porcentaje de descuento (1% — 95%)
            </label>
            <div style="display:flex; align-items:center; gap:12px;">
                <input asp-for="PorcentajeDescuento"
                       type="number" min="1" max="95" step="1"
                       placeholder="Ej: 10"
                       style="max-width:140px;" />
                <span style="font-size:24px; font-weight:700; color:#111827;">%</span>
            </div>
            <div class="field-error"><span asp-validation-for="PorcentajeDescuento"></span></div>
        </div>
        <div class="adm-form-grid-2">
            <div class="adm-field">
                <label asp-for="FechaInicio">Válido desde</label>
                <input asp-for="FechaInicio" type="date"
                       value="@Model.FechaInicio.ToString("yyyy-MM-dd")" />
                <div class="field-error"><span asp-validation-for="FechaInicio"></span></div>
            </div>
            <div class="adm-field">
                <label asp-for="FechaVencimiento">Vence el</label>
                <input asp-for="FechaVencimiento" type="date"
                       value="@Model.FechaVencimiento.ToString("yyyy-MM-dd")" />
                <div class="field-error"><span asp-validation-for="FechaVencimiento"></span></div>
            </div>
        </div>
        <div class="adm-field">
            <div class="adm-check">
                <input asp-for="Estado" type="checkbox" />
                <label asp-for="Estado">Cupón activo (disponible para usar)</label>
            </div>
        </div>
        <div class="adm-form-footer">
            <button type="submit" class="btn-adm-primary">Guardar cupón</button>
            <a href="@Url.Action("Cupones")" class="btn-adm-edit">Cancelar</a>
        </div>
    </form>
</div>