@model IEnumerable<Sistema_BC_SMART_POINT.Models.Venta>
@{
    ViewData["Title"] = "Ventas";
    Layout = "_AdminLayout";
    string? estadoFiltro = ViewBag.EstadoFiltro;
}

<div class="adm-page-header">
    <div>
        <h1>Ventas</h1>
        <p>
            @Model.Count() pedidos
            @if (!string.IsNullOrEmpty(estadoFiltro))
            {
                <span>· filtrado por <strong>@estadoFiltro</strong></span>
            }
        </p>
    </div>
</div>

<div class="filtro-tabs">
    <a href="@Url.Action("Ventas")"
       class="filtro-tab @(estadoFiltro == null ? "active" : "")">
        Todos
        <span class="count">@(ViewBag.TotalPendientes + ViewBag.TotalVerificando + ViewBag.TotalPagados + ViewBag.TotalRechazados)</span>
    </a>
    <a href="@Url.Action("Ventas", new { estado = "En verificación" })"
       class="filtro-tab @(estadoFiltro == "En verificación" ? "active" : "")">
        En verificación
        <span class="count">@ViewBag.TotalVerificando</span>
    </a>
    <a href="@Url.Action("Ventas", new { estado = "Pendiente" })"
       class="filtro-tab @(estadoFiltro == "Pendiente" ? "active" : "")">
        Pendientes
        <span class="count">@ViewBag.TotalPendientes</span>
    </a>
    <a href="@Url.Action("Ventas", new { estado = "Pagado" })"
       class="filtro-tab @(estadoFiltro == "Pagado" ? "active" : "")">
        Pagados
        <span class="count">@ViewBag.TotalPagados</span>
    </a>
    <a href="@Url.Action("Ventas", new { estado = "Rechazado" })"
       class="filtro-tab @(estadoFiltro == "Rechazado" ? "active" : "")">
        Rechazados
        <span class="count">@ViewBag.TotalRechazados</span>
    </a>
</div>

<div class="adm-card">
    <table class="adm-table">
        <thead>
            <tr>
                <th>Pedido</th>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Método</th>
                <th>Total</th>
                <th>Comprobante</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="td-empty">No hay ventas con ese filtro.</td>
                </tr>
            }
            @foreach (var v in Model)
            {
                <tr>
                    <td>
                        <div class="td-id">#@v.IdVenta</div>
                        <div class="td-sub">@v.DetallesVenta.Count ítem(s)</div>
                    </td>
                    <td>
                        <div class="td-nombre">@v.Cliente?.Usuario?.Nombres @v.Cliente?.Usuario?.Apellidos</div>
                        <div class="td-email">@v.Cliente?.Usuario?.Email</div>
                    </td>
                    <td class="td-fecha">
                        @v.FechaVenta.ToString("dd/MM/yyyy")
                        <div class="td-hora">@v.FechaVenta.ToString("HH:mm")</div>
                    </td>
                    <td class="td-metodo">@v.MetodoPago</td>
                    <td class="td-total">S/ @v.TotalVenta.ToString("0.00")</td>
                    <td>
                        @{
                            var metodosComp = new[] { "Yape", "Plin", "Transferencia" };
                        }
                        @if (!string.IsNullOrEmpty(v.ComprobantePago))
                        {
                            <a href="@v.ComprobantePago" target="_blank" class="comp-badge comp-ok">Ver imagen →</a>
                        }
                        else if (metodosComp.Contains(v.MetodoPago))
                        {
                            <span class="comp-badge comp-pendiente">Sin subir</span>
                        }
                        else
                        {
                            <span class="comp-na">N/A</span>
                        }
                    </td>
                    <td>
                        @{
                            string badgeClass = v.EstadoPago switch
                            {
                                "Pagado" => "badge-pagado",
                                "En verificación" => "badge-verificando",
                                "Rechazado" => "badge-rechazado",
                                "Anulado" => "badge-anulado",
                                _ => "badge-pendiente"
                            };
                        }
                        <span class="badge-estado @badgeClass">@v.EstadoPago</span>
                    </td>
                    <td>
                        <a href="@Url.Action("DetalleVenta", new { id = v.IdVenta })"
                           class="btn-adm-edit">Ver detalle</a>
                    </td>
                </tr>
            }
</tbody>
    </table>
</div>
<div class="bc-pagination-wrap">
    <!-- Selector registros por página -->
    <div class="bc-pagination-size">
        <span>Mostrar</span>
        <select onchange="cambiarTamano(this.value)" class="bc-pagination-select">
            @{
                var t = (int)ViewBag.TamanoPagina;
            }
            @if (t == 5)
            {
                <option value="5" selected>5</option>
            }
            else
            {
                <option value="5">5</option>
            }
            @if (t == 10)
            {
                <option value="10" selected>10</option>
            }
            else
            {
                <option value="10">10</option>
            }
            @if (t == 20)
            {
                <option value="20" selected>20</option>
            }
            else
            {
                <option value="20">20</option>
            }
        </select>
        <span>de @ViewBag.TotalRegistros ventas</span>
    </div>

    <!-- Botones de página -->
    <div class="bc-pagination">
        @{
            int paginaActual = (int)ViewBag.PaginaActual;
            int totalPaginas = (int)ViewBag.TotalPaginas;
            int rango = 2;
        }

        @if (paginaActual > 1)
        {
            <a class="bc-page-btn" asp-action="Ventas"
               asp-route-pagina="1"
               asp-route-tamano="@ViewBag.TamanoPagina"
               asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-metodo="@ViewBag.MetodoFiltro">« Primera</a>

            <a class="bc-page-btn" asp-action="Ventas"
               asp-route-pagina="@(paginaActual - 1)"
               asp-route-tamano="@ViewBag.TamanoPagina"
               asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-metodo="@ViewBag.MetodoFiltro">← Anterior</a>
        }

        @if (paginaActual - rango > 1)
        {
            <span class="bc-page-btn">...</span>
        }

        @for (int i = Math.Max(1, paginaActual - rango); i <= Math.Min(totalPaginas, paginaActual + rango); i++)
        {
            <a class="bc-page-btn @(i == paginaActual ? "bc-page-btn--active" : "")"
               asp-action="Ventas"
               asp-route-pagina="@i"
               asp-route-tamano="@ViewBag.TamanoPagina"
               asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-metodo="@ViewBag.MetodoFiltro">@i</a>
        }

        @if (paginaActual + rango < totalPaginas)
        {
            <span class="bc-page-btn">...</span>
        }

        @if (paginaActual < totalPaginas)
        {
            <a class="bc-page-btn" asp-action="Ventas"
               asp-route-pagina="@(paginaActual + 1)"
               asp-route-tamano="@ViewBag.TamanoPagina"
               asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-metodo="@ViewBag.MetodoFiltro">Siguiente →</a>

            <a class="bc-page-btn" asp-action="Ventas"
               asp-route-pagina="@totalPaginas"
               asp-route-tamano="@ViewBag.TamanoPagina"
               asp-route-estado="@ViewBag.EstadoFiltro"
               asp-route-metodo="@ViewBag.MetodoFiltro">Última »</a>
        }
    </div>
</div>
</div>

@section Scripts {
    <script>
        function cambiarTamano(tamano) {
            const url = new URL(window.location.href);
            url.searchParams.set('tamano', tamano);
            url.searchParams.set('pagina', 1);
            window.location.href = url.toString();
        }
    </script>
}
<style>
    .bc-pagination-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 20px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .bc-pagination-size {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.875rem;
        color: #4A4A4F; /* ratio ~5.2:1 sobre #fff ✓ */
    }

    .bc-pagination-select {
        border: 1px solid #767676;
        border-radius: 8px;
        padding: 4px 8px;
        font-size: 0.875rem;
        color: #1D1D1F;
        background: #fff;
        cursor: pointer;
    }

    .bc-pagination {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .bc-page-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        padding: 0 10px;
        border: 1px solid #767676; /* ratio ~4.6:1 ✓ */
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        color: #1D1D1F;
        text-decoration: none;
        transition: border-color 0.2s, background 0.2s;
    }

        .bc-page-btn:hover {
            border-color: #7A5200;
            color: #1D1D1F;
        }

    .bc-page-btn--active {
        background: #7A5200; /* amarillo oscuro ratio ~5.2:1 sobre #fff ✓ */
        border-color: #7A5200;
        color: #fff !important;
    }
    .adm-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--bc-borde);
    }

        .adm-page-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--bc-texto-1);
            margin: 0 0 4px;
            letter-spacing: -0.02em;
        }

        .adm-page-header p {
            font-size: 0.825rem;
            color: var(--bc-texto-2);
            margin: 0;
        }

        .adm-page-header strong {
            color: var(--bc-texto-1);
            font-weight: 600;
        }

    .filtro-tabs {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
    }

    .filtro-tab {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--bc-texto-2);
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 8px;
        padding: 0.4rem 0.85rem;
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s, background 0.15s;
        white-space: nowrap;
    }

        .filtro-tab:hover {
            color: var(--bc-texto-1);
            border-color: var(--bc-texto-2);
        }

        .filtro-tab.active {
            background: var(--bc-negro);
            color: var(--bc-amarillo);
            border-color: var(--bc-negro);
            font-weight: 600;
        }

            .filtro-tab.active .count {
                background: rgba(245, 197, 0, 0.15);
                color: var(--bc-amarillo);
            }

    .count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        background: var(--bc-fondo);
        color: var(--bc-texto-2);
        border-radius: 20px;
        padding: 1px 7px;
        min-width: 22px;
    }

    .adm-card {
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 16px;
        overflow: hidden;
    }

    .adm-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

        .adm-table thead tr {
            background: var(--bc-fondo);
        }

        .adm-table th {
            padding: 0.75rem 1.25rem;
            text-align: left;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--bc-texto-2);
            text-transform: uppercase;
            letter-spacing: 0.07em;
            border-bottom: 1px solid var(--bc-borde);
            white-space: nowrap;
        }

        .adm-table td {
            padding: 0.85rem 1.25rem;
            border-bottom: 1px solid var(--bc-borde);
            color: var(--bc-texto-1);
            vertical-align: middle;
        }

        .adm-table tbody tr:last-child td {
            border-bottom: none;
        }

        .adm-table tbody tr:hover {
            background: var(--bc-fondo);
        }

    .td-empty {
        text-align: center;
        padding: 2.5rem;
        color: var(--bc-texto-2);
        font-size: 0.875rem;
    }

    .td-id {
        font-weight: 700;
        color: var(--bc-texto-1);
        font-size: 0.9rem;
    }

    .td-sub {
        font-size: 0.72rem;
        color: var(--bc-texto-2);
        margin-top: 2px;
    }

    .td-nombre {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--bc-texto-1);
    }

    .td-email {
        font-size: 0.72rem;
        color: var(--bc-texto-2);
        margin-top: 2px;
    }

    .td-fecha {
        font-size: 0.8rem;
        color: var(--bc-texto-2);
        white-space: nowrap;
        line-height: 1.6;
    }

    .td-hora {
        font-size: 0.7rem;
        color: var(--bc-texto-2);
    }

    .td-metodo {
        font-size: 0.825rem;
        color: var(--bc-texto-1);
    }

    .td-total {
        font-weight: 700;
        color: var(--bc-texto-1);
        white-space: nowrap;
    }

    .comp-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        text-decoration: none;
        white-space: nowrap;
    }

    .comp-ok {
        background: #f0fdf4;
        color: #15803d;
        transition: background 0.15s;
    }

        .comp-ok:hover {
            background: #dcfce7;
        }

    .comp-pendiente {
        background: #fff7ed;
        color: #c2410c;
    }

    .comp-na {
        font-size: 0.75rem;
        color: var(--bc-texto-2);
    }

    .badge-estado {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        letter-spacing: 0.02em;
        white-space: nowrap;
    }

    .badge-pagado {
        background: #f0fdf4;
        color: #15803d;
    }

    .badge-verificando {
        background: #fff7ed;
        color: #c2410c;
    }

    .badge-rechazado {
        background: #fff1f2;
        color: #b91c1c;
    }

    .badge-anulado {
        background: #f5f5f7;
        color: var(--bc-texto-2);
    }

    .badge-pendiente {
        background: #f5f5f7;
        color: var(--bc-texto-2);
    }

    .btn-adm-edit {
        display: inline-flex;
        align-items: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--bc-texto-2);
        background: transparent;
        border: 1px solid var(--bc-borde);
        border-radius: 8px;
        padding: 0.35rem 0.85rem;
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s;
        white-space: nowrap;
    }

        .btn-adm-edit:hover {
            color: var(--bc-texto-1);
            border-color: var(--bc-texto-2);
        }

    @@media (max-width: 700px) {
        .adm-table th, .adm-table td

    {
        padding: 0.65rem 0.75rem;
    }

    }
</style>

