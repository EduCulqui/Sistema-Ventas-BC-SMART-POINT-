@model IEnumerable<Sistema_BC_SMART_POINT.Models.Producto>

@{
    ViewData["Title"] = "Catálogo";

    var categorias = ViewBag.Categorias as IEnumerable<Sistema_BC_SMART_POINT.Models.Categoria>;
    int? categoriaSeleccionada = ViewBag.CategoriaId;
    string busqueda = ViewBag.Busqueda ?? "";
    string orden = ViewBag.Orden ?? "";

    var productos = Model?.ToList() ?? new List<Sistema_BC_SMART_POINT.Models.Producto>();
}

<section class="hero-video-bc">
    <video autoplay muted loop playsinline>
        <source src="/videos/videoiphone.mp4" type="video/mp4" />
        Tu navegador no soporta video HTML5.
    </video>
</section>

<section class="catalogo-page">

    <div class="catalogo-hero">
        <div>
            <span class="catalogo-label">BC Smart Point</span>
            <h1>Catálogo de productos</h1>
            <p>Explora los productos disponibles, revisa el stock y agrega al carrito.</p>
        </div>
    </div>

    <form method="get" asp-action="Index" class="catalogo-filtros">
        <div class="filtro-busqueda">
            <span>🔎</span>
            <input type="text"
                   name="busqueda"
                   value="@busqueda"
                   placeholder="Buscar por nombre o modelo..." />
        </div>

        <select name="categoriaId">
            <option value="">Todas las categorías</option>
            @foreach (var cat in categorias ?? Enumerable.Empty<Sistema_BC_SMART_POINT.Models.Categoria>())
            {
                <option value="@cat.IdCategoria"
                        selected="@(categoriaSeleccionada == cat.IdCategoria ? "selected" : null)">
                    @cat.NomCategoria
                </option>
            }
        </select>

        <select name="orden">
            <option value="">Nombre A-Z</option>
            <option value="precio_asc" selected="@(orden == "precio_asc" ? "selected" : null)">
                Precio: menor a mayor
            </option>
            <option value="precio_desc" selected="@(orden == "precio_desc" ? "selected" : null)">
                Precio: mayor a menor
            </option>
        </select>

        <button type="submit" class="btn-filtrar">Filtrar</button>

        <a href="@Url.Action("Index")" class="btn-limpiar">
            Limpiar
        </a>
    </form>

    @if (!productos.Any())
    {
        <div class="catalogo-vacio">
            <div class="vacio-icono">×</div>
            <h2>No se encontraron productos</h2>
            <p>No hay productos activos con esos criterios.</p>

            <a href="@Url.Action("Index")" class="btn-principal">
                Ver todos los productos
            </a>
        </div>
    }
    else
    {
        <div class="productos-grid">
            @foreach (var p in productos)
            {
                string stockClass = p.StockActual == 0 ? "stock-empty"
                : p.StockActual <= p.StockMinimo ? "stock-low"
                : "stock-ok";

                string stockText = p.StockActual == 0 ? "Sin stock"
                : p.StockActual <= p.StockMinimo ? $"Últimas unidades ({p.StockActual})"
                : $"En stock ({p.StockActual})";

                <article class="producto-card @(p.StockActual == 0 ? "producto-agotado" : "")">

                    <div class="producto-img-box">
                        @if (p.Categoria != null)
                        {
                            <span class="producto-categoria">@p.Categoria.NomCategoria</span>
                        }

                        <img src="@(string.IsNullOrEmpty(p.ImagenUrl) ? "/images/no-image.png" : p.ImagenUrl)"
                             alt="@p.Nombre" />
                    </div>

                    <div class="producto-info">
                        <h3>@p.Nombre</h3>

                        <p class="producto-specs">
                            @string.Join(" · ", new[] { p.Modelo, p.Color, p.Capacidad }
                                     .Where(s => !string.IsNullOrEmpty(s)))
                        </p>

                        <div class="producto-precio">
                            <span>S/</span>
                            <strong>@p.Precio.ToString("0.00")</strong>
                        </div>

                        <span class="producto-stock @stockClass">
                            @stockText
                        </span>

                        <a href="@Url.Action("Detalle", new { id = p.IdProducto })"
                           class="btn-detalle @(p.StockActual == 0 ? "disabled" : "")">
                            Ver detalle
                        </a>
                    </div>

                </article>
            }
        </div>
    }

</section>

<style>
    body {
        background: #f5f5f5;
    }

    .hero-video-bc {
        max-width: 1180px;
        margin: 32px auto 24px;
        border-radius: 18px;
        overflow: hidden;
        background: #1c1c1c;
        border-left: 8px solid #ffc928;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
    }

        .hero-video-bc video {
            width: 100%;
            height: 320px;
            display: block;
            object-fit: cover;
            background: #1c1c1c;
        }

    .catalogo-page {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 20px 60px;
    }

    .catalogo-hero {
        background: #1c1c1c;
        color: #ffffff;
        border-radius: 18px;
        padding: 34px;
        margin-bottom: 24px;
        border-left: 8px solid #ffc928;
    }

    .catalogo-label {
        display: inline-block;
        margin-bottom: 10px;
        color: #ffc928;
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .catalogo-hero h1 {
        margin: 0 0 8px;
        font-size: 36px;
        font-weight: 800;
    }

    .catalogo-hero p {
        margin: 0;
        color: #d6d6d6;
        font-size: 16px;
    }

    .catalogo-filtros {
        display: grid;
        grid-template-columns: minmax(240px, 1fr) 210px 210px auto auto;
        gap: 12px;
        align-items: center;
        background: #ffffff;
        border: 1px solid #e4e4e4;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 26px;
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.04);
    }

    .filtro-busqueda {
        display: flex;
        align-items: center;
        gap: 10px;
        height: 44px;
        padding: 0 12px;
        background: #f8f8f8;
        border: 1px solid #dddddd;
        border-radius: 10px;
    }

        .filtro-busqueda input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            color: #1c1c1c;
            font-size: 14px;
        }

    .catalogo-filtros select {
        height: 44px;
        border: 1px solid #dddddd;
        border-radius: 10px;
        background: #f8f8f8;
        color: #1c1c1c;
        padding: 0 12px;
        font-size: 14px;
        outline: none;
    }

        .catalogo-filtros select:focus,
        .filtro-busqueda:focus-within {
            border-color: #ffc928;
            box-shadow: 0 0 0 3px rgba(255, 201, 40, 0.22);
        }

    .btn-filtrar,
    .btn-principal {
        height: 44px;
        border: none;
        border-radius: 10px;
        background: #ffc928;
        color: #1c1c1c;
        font-weight: 800;
        padding: 0 18px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s ease;
    }

        .btn-filtrar:hover,
        .btn-principal:hover {
            background: #1c1c1c;
            color: #ffc928;
        }

    .btn-limpiar {
        height: 44px;
        border-radius: 10px;
        border: 1px solid #dddddd;
        color: #1c1c1c;
        background: #ffffff;
        text-decoration: none;
        font-weight: 700;
        padding: 0 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-limpiar:hover {
            border-color: #ffc928;
            color: #000000;
        }

    .productos-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(235px, 1fr));
        gap: 20px;
    }

    .producto-card {
        background: #ffffff;
        border: 1px solid #e5e5e5;
        border-radius: 18px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.05);
        transition: 0.2s ease;
    }

        .producto-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.09);
        }

    .producto-agotado {
        opacity: 0.65;
    }

    .producto-img-box {
        position: relative;
        height: 210px;
        background: #fafafa;
        border-bottom: 1px solid #eeeeee;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 22px;
    }

        .producto-img-box img {
            max-width: 100%;
            max-height: 170px;
            object-fit: contain;
        }

    .producto-categoria {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #1c1c1c;
        color: #ffc928;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 12px;
        font-weight: 800;
    }

    .producto-info {
        padding: 18px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

        .producto-info h3 {
            margin: 0 0 6px;
            color: #1c1c1c;
            font-size: 18px;
            font-weight: 800;
        }

    .producto-specs {
        min-height: 38px;
        margin: 0 0 12px;
        color: #666666;
        font-size: 13px;
        line-height: 1.4;
    }

    .producto-precio {
        display: flex;
        align-items: baseline;
        gap: 4px;
        margin-bottom: 10px;
        color: #1c1c1c;
    }

        .producto-precio span {
            font-size: 14px;
            font-weight: 700;
        }

        .producto-precio strong {
            font-size: 24px;
            font-weight: 900;
        }

    .producto-stock {
        width: fit-content;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 12px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .stock-ok {
        background: #e8f8ed;
        color: #137a35;
    }

    .stock-low {
        background: #fff4d4;
        color: #9a6a00;
    }

    .stock-empty {
        background: #ffe0e0;
        color: #a30000;
    }

    .btn-detalle {
        margin-top: auto;
        min-height: 42px;
        border-radius: 10px;
        background: #1c1c1c;
        color: #ffffff;
        font-weight: 800;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s ease;
    }

        .btn-detalle:hover {
            background: #ffc928;
            color: #1c1c1c;
        }

        .btn-detalle.disabled {
            pointer-events: none;
            opacity: 0.5;
        }

    .catalogo-vacio {
        text-align: center;
        background: #ffffff;
        border: 1px solid #e5e5e5;
        border-radius: 18px;
        padding: 60px 20px;
    }

    .vacio-icono {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        border: 2px solid #1c1c1c;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 36px;
        color: #1c1c1c;
    }

    .catalogo-vacio h2 {
        margin: 0 0 8px;
        color: #1c1c1c;
    }

    .catalogo-vacio p {
        color: #666666;
        margin-bottom: 20px;
    }

    @@media (max-width: 900px) {
        .catalogo-filtros {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 768px) {
        .hero-video-bc {
            margin: 20px 14px 18px;
            border-radius: 14px;
        }

            .hero-video-bc video {
                height: 190px;
            }
    }

    @@media (max-width: 620px) {
        .catalogo-page {
            padding: 0 14px 50px;
        }

        .catalogo-hero {
            padding: 24px;
        }

            .catalogo-hero h1 {
                font-size: 28px;
            }

        .catalogo-filtros {
            grid-template-columns: 1fr;
        }
    }
</style>