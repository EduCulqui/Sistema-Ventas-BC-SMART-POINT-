<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BC Smart Point</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sistema_BC_SMART_POINT.styles.css" asp-append-version="true" />
    <style>
        .dropdown-menu-bc {
            background: #1A1A1A;
            border: 1px solid #2E2E2E;
            border-radius: 12px;
            padding: 8px;
            min-width: 190px;
            box-shadow: 0 8px 24px rgba(0,0,0,.5);
            margin-top: 6px !important;
        }

        .dropdown-item-bc {
            display: block;
            padding: 9px 14px;
            font-size: 0.88rem;
            color: #E5E5E5;
            text-decoration: none;
            border-radius: 8px;
            transition: background .15s, color .15s;
            font-weight: 500;
        }

            .dropdown-item-bc:hover {
                background: #2E2E2E;
                color: var(--bc-amarillo);
            }

        .dropdown-divider-bc {
            border-color: #2E2E2E;
            margin: 4px 0;
        }

        .nav-link-bc.dropdown-toggle::after {
            border-top-color: #E5E5E5;
        }

        .footer-bc-mini {
            background: var(--bc-negro);
            border-top: 1px solid #2E2E2E;
            padding: 24px 0 18px;
            margin-top: 48px;
        }

        .footer-bc-mini__inner {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 18px;
        }

        .footer-bc-mini__contact {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .footer-bc-mini__contact-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: #777;
            text-decoration: none;
            transition: color .15s;
        }

            .footer-bc-mini__contact-item:hover {
                color: var(--bc-amarillo);
            }

        .footer-bc-mini__links {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

            .footer-bc-mini__links a {
                font-size: 0.78rem;
                color: #777 !important;
                text-decoration: none !important;
                transition: color .15s;
            }

                .footer-bc-mini__links a:hover {
                    color: var(--bc-amarillo) !important;
                }

            .footer-bc-mini__links .sep {
                color: #333;
                font-size: 0.75rem;
            }

        .footer-bc-mini__copy {
            border-top: 1px solid #2E2E2E;
            padding-top: 14px;
            text-align: center;
            font-size: 0.72rem;
            color: #444;
        }

        .footer-bc-mini .bc-yellow {
            color: var(--bc-amarillo) !important;
        }

        .footer-bc-mini .bc-white {
            color: #fff !important;
        }

        .footer-bc-mini a {
            color: #777 !important;
            text-decoration: none !important;
        }

            .footer-bc-mini a:hover {
                color: var(--bc-amarillo) !important;
            }

        .footer-bc-mini .footer-bc-mini__brand .bc-yellow {
            color: var(--bc-amarillo) !important;
        }

        .footer-bc-mini .footer-bc-mini__brand .bc-white {
            color: #fff !important;
        }

        .footer-bc-mini .footer-social-btn {
            color: #aaa !important;
        }

            .footer-bc-mini .footer-social-btn:hover {
                color: var(--bc-amarillo) !important;
                border-color: var(--bc-amarillo) !important;
            }

        @@media (max-width: 768px) {
            .footer-bc-mini__inner {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-bc" aria-label="Navegación principal">
            <div class="container">

                <a class="navbar-brand-bc" asp-controller="Home" asp-action="Index">
                    BC Smart Point
                </a>

                <button class="navbar-toggler navbar-toggler-bc" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false"
                        aria-label="Abrir menú">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">

                    <ul class="navbar-nav me-auto align-items-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link-bc" asp-controller="Catalogo" asp-action="Index">
                                Catálogo
                            </a>
                        </li>
                        @await Component.InvokeAsync("Categorias")
                    </ul>

                    <form class="navbar-search-form me-3" method="get"
                          asp-controller="Home" asp-action="Index"
                          role="search" aria-label="Buscar productos">
                        <input class="navbar-search-input" type="search"
                               name="busqueda" placeholder="Buscar productos..."
                               value="@(ViewBag.BusquedaActual ?? "")"
                               aria-label="Buscar productos" />
                        <button class="navbar-search-btn" type="submit" aria-label="Buscar">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 viewBox="0 0 24 24" aria-hidden="true">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                        </button>
                    </form>

                    <ul class="navbar-nav align-items-center gap-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-user-bc">
                                    Hola, @User.Identity.Name.Split(' ')[0]
                                </span>
                            </li>

                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link-bc"
                                       asp-controller="Admin" asp-action="Dashboard">
                                        Panel Admin
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link-bc"
                                       asp-controller="Carrito" asp-action="MisPedidos">
                                        Mis pedidos
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-bc"
                                       asp-controller="Carrito" asp-action="Index"
                                       aria-label="Ver carrito">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                             fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                            <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4z" />
                                        </svg>
                                        Carrito
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="btn-bc-outline btn-sm-bc"
                                   asp-controller="Auth" asp-action="Logout">
                                    Cerrar sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn-bc btn-sm-bc ms-1"
                                   asp-controller="Auth" asp-action="Login">
                                    Iniciar sesión
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    @if (ViewData["FullWidth"] != null && (bool)ViewData["FullWidth"])
    {
        @if (TempData["Exito"] != null)
        {
            <div class="container pt-2">
                <div class="alert alert-bc-exito alert-dismissible fade show" role="alert">
                    @TempData["Exito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container pt-2">
                <div class="alert alert-bc-error alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        <main role="main" aria-label="Contenido principal">@RenderBody()</main>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3" aria-label="Contenido principal">
                @if (TempData["Exito"] != null)
                {
                    <div class="alert alert-bc-exito alert-dismissible fade show" role="alert">
                        @TempData["Exito"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-bc-error alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    }

    @if (ViewData["HideFooter"] == null || !(bool)ViewData["HideFooter"])
    {
        <footer class="footer-bc-mini" aria-label="Pie de página">
            <div class="container">
                <div class="footer-bc-mini__inner">

                    <a class="footer-brand__logo" asp-controller="Home" asp-action="Index">
                        <span class="bc-yellow">BC</span>
                        <span class="bc-white">Smart Point</span>
                    </a>

                    <div class="footer-bc-mini__contact">
                        <a href="tel:+51999000000" class="footer-bc-mini__contact-item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21 16.92z" />
                            </svg>
                            +51 999 000 000
                        </a>
                        <a href="mailto:info@bcsmartpoint.com" class="footer-bc-mini__contact-item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="2" y="4" width="20" height="16" rx="2" />
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                            </svg>
                            info@bcsmartpoint.com
                        </a>
                        <span class="footer-bc-mini__contact-item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0z" />
                                <circle cx="12" cy="10" r="3" />
                            </svg>
                            Cajamarca, Perú
                        </span>
                    </div>

                    <div class="footer-bc-mini__links">
                        <a asp-controller="Home" asp-action="Privacy">Política de privacidad</a>
                        <span class="sep">·</span>
                        <a href="#">Términos y condiciones</a>
                        <span class="sep">·</span>
                        <a href="#">Garantías</a>
                    </div>

                    <div class="footer-brand__social">
                        <a href="#" class="footer-social-btn" aria-label="Facebook">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                            </svg>
                        </a>
                        <a href="#" class="footer-social-btn" aria-label="Instagram">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="2" y="2" width="20" height="20" rx="5" />
                                <circle cx="12" cy="12" r="4" />
                                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" />
                            </svg>
                        </a>
                        <a href="#" class="footer-social-btn" aria-label="TikTok">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z" />
                            </svg>
                        </a>
                        <a href="#" class="footer-social-btn" aria-label="WhatsApp">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
                            </svg>
                        </a>
                    </div>

                </div>
                <div class="footer-bc-mini__copy">
                    © 2026 BC Smart Point · Todos los derechos reservados
                </div>
            </div>
        </footer>
    }



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script src="https://cdn.userway.org/widget.js" data-account="aHTw6vRJQ2"></script>
</body>
</html>

