<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BC Smart Point Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --bc-negro: #1A1A1A;
            --bc-negro-hover: #2E2E2E;
            --bc-amarillo: #F5C500;
            --bc-fondo: #F5F5F7;
            --bc-blanco: #FFFFFF;
            --bc-texto-1: #1D1D1F;
            --bc-texto-2: #6E6E73;
            --bc-borde: #D2D2D7;
            --sidebar-w: 240px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--bc-fondo);
            color: var(--bc-texto-1);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 0.9rem;
        }

        /* ── Layout base ────────────────────────────── */
        .adm-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ── Sidebar ────────────────────────────────── */
        .adm-sidebar {
            width: var(--sidebar-w);
            min-width: var(--sidebar-w);
            background: var(--bc-negro);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding: 0;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
        }

        .adm-brand {
            display: block;
            color: var(--bc-amarillo);
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.01em;
            text-decoration: none;
            padding: 1.5rem 1.25rem 0.25rem;
            line-height: 1.2;
        }

            .adm-brand:hover {
                color: var(--bc-amarillo);
            }

        .adm-brand-sub {
            display: block;
            font-size: 0.7rem;
            color: var(--bc-texto-2);
            padding: 0 1.25rem 1.25rem;
            letter-spacing: 0.02em;
            border-bottom: 1px solid #2E2E2E;
            margin-bottom: 0.75rem;
        }

        .adm-nav-label {
            font-size: 0.65rem;
            font-weight: 600;
            color: #444;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 0.75rem 1.25rem 0.35rem;
        }

        .adm-nav {
            display: flex;
            flex-direction: column;
            gap: 2px;
            padding: 0 0.75rem;
            margin-bottom: 0.5rem;
        }

            .adm-nav a {
                display: flex;
                align-items: center;
                gap: 10px;
                color: #B0B0B0;
                text-decoration: none;
                font-size: 0.875rem;
                padding: 0.5rem 0.75rem;
                border-radius: 8px;
                transition: background-color 0.15s, color 0.15s;
            }

                .adm-nav a:hover {
                    background: var(--bc-negro-hover);
                    color: #E5E5E5;
                }

                .adm-nav a.active {
                    background: var(--bc-amarillo);
                    color: var(--bc-negro);
                    font-weight: 600;
                }

                    .adm-nav a.active .adm-icon {
                        color: var(--bc-negro);
                    }

        .adm-icon {
            width: 16px;
            height: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #555;
            flex-shrink: 0;
        }

        .adm-logout {
            margin-top: auto;
            padding: 1rem 0.75rem 1.5rem;
            border-top: 1px solid #2E2E2E;
        }

            .adm-logout a {
                display: flex;
                align-items: center;
                gap: 8px;
                color: var(--bc-texto-2);
                text-decoration: none;
                font-size: 0.825rem;
                padding: 0.5rem 0.75rem;
                border-radius: 8px;
                transition: color 0.2s, background-color 0.2s;
            }

                .adm-logout a:hover {
                    color: #FF453A;
                    background: rgba(255, 69, 58, 0.08);
                }

        /* Main  */
        .adm-main {
            flex: 1;
            padding: 2rem 2.5rem;
            min-width: 0;
        }

        /*  Alertas */
        .adm-alert {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 1.5rem;
        }

            .adm-alert.success {
                background: #f0fdf4;
                border: 1px solid #86efac;
                color: #15803d;
            }

            .adm-alert.error {
                background: #fff1f2;
                border: 1px solid #fca5a5;
                color: #b91c1c;
            }
    </style>
</head>
<body>
    <div class="adm-wrapper">

        <aside class="adm-sidebar">

            <a class="adm-brand" href="@Url.Action("Dashboard", "Admin")">BC Smart Point</a>
            <span class="adm-brand-sub">Panel de administración</span>

            <div class="adm-nav-label">General</div>
            <nav class="adm-nav">
                <a href="@Url.Action("Dashboard", "Admin")"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <span class="adm-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4zM3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707zM2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10zm9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5zm.754-4.246a.389.389 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.389.389 0 0 0-.029-.518z" />
                            <path fill-rule="evenodd" d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 1.602-2.932 1.25C11.309 13.488 9.475 13 8 13c-1.474 0-3.31.488-4.615.911-1.087.352-2.49.003-2.932-1.25A7.988 7.988 0 0 1 0 10zm8-7a7 7 0 0 0-6.603 9.329c.203.575.923.876 1.68.63C4.397 12.533 6.358 12 8 12s3.604.532 4.923.96c.757.245 1.477-.056 1.68-.631A7 7 0 0 0 8 3z" />
                        </svg>
                    </span>
                    Dashboard
                </a>
            </nav>

            <div class="adm-nav-label">Inventario</div>
            <nav class="adm-nav">
                <a href="@Url.Action("Productos", "Admin")"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString()!.Contains("Producto") == true ? "active" : "")">
                    <span class="adm-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M0 2.5A.5.5 0 0 1 .5 2H2a.5.5 0 0 1 .485.379L2.89 4H14.5a.5.5 0 0 1 .485.621l-1.5 6A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.485-.379L1.61 3H.5a.5.5 0 0 1-.5-.5zM3.14 5l1.25 5h8.22l1.25-5H3.14zM5 13a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0zm9-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0z" />
                        </svg>
                    </span>
                    Productos
                </a>
                <a href="@Url.Action("Categorias", "Admin")"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString()!.Contains("Categoria") == true ? "active" : "")">
                    <span class="adm-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z" />
                        </svg>
                    </span>
                    Categorías
                </a>
                <a href="@Url.Action("Proveedores", "Admin")"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString()!.Contains("Proveedor") == true ? "active" : "")">
                    <span class="adm-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M6 .5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1H9v1.07a7.001 7.001 0 0 1 3.274 12.474l.601.602a.5.5 0 0 1-.707.708l-.746-.746A6.97 6.97 0 0 1 8 15a6.97 6.97 0 0 1-3.422-.892l-.746.746a.5.5 0 0 1-.707-.708l.602-.602A7.001 7.001 0 0 1 7 2.07V1h-.5A.5.5 0 0 1 6 .5z" />
                        </svg>
                    </span>
                    Proveedores
                </a>
            </nav>

            <div class="adm-nav-label">Operaciones</div>
            <nav class="adm-nav">
                <a href="@Url.Action("Ventas", "Admin")"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString()!.Contains("Venta") == true ? "active" : "")">
                    <span class="adm-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M0 2.5A.5.5 0 0 1 .5 2h3a.5.5 0 0 1 0 1H1v1h3.5a1 1 0 0 1 1 1v3.5h1a.5.5 0 0 1 0 1H5V13a1 1 0 0 1-1 1H1.5a.5.5 0 0 1 0-1H4v-2.5H.5a.5.5 0 0 1-.5-.5v-5zM9 2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 .5.5v5a.5.5 0 0 1-.5.5H14v2.5h1.5a.5.5 0 0 1 0 1H12a1 1 0 0 1-1-1v-2.5H9.5a.5.5 0 0 1 0-1h1V5.5a1 1 0 0 1 1-1H14V3h-4.5a.5.5 0 0 1-.5-.5z" />
                        </svg>
                    </span>
                    Ventas
                </a>
                <a href="@Url.Action("Envios", "Admin")"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString()!.Contains("Envio") == true ? "active" : "")">
                    <span class="adm-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M0 3.5A1.5 1.5 0 0 1 1.5 2h9A1.5 1.5 0 0 1 12 3.5V5h1.02a1.5 1.5 0 0 1 1.17.563l1.481 1.85a1.5 1.5 0 0 1 .329.938V10.5a1.5 1.5 0 0 1-1.5 1.5H14a2 2 0 1 1-4 0H5a2 2 0 1 1-3.998-.085A1.5 1.5 0 0 1 0 10.5v-7z" />
                        </svg>
                    </span>
                    Envíos
                </a>
                <a href="@Url.Action("Clientes", "Admin")"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString()!.Contains("Cliente") == true ? "active" : "")">
                    <span class="adm-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                            <path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z" />
                            <path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z" />
                        </svg>
                    </span>
                    Clientes
                </a>
                <a href="@Url.Action("Cupones", "Admin")"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString()!.Contains("Cupon") == true ? "active" : "")">
                    <span class="adm-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M1 4.5a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v2.082a.5.5 0 0 1-.423.493C13.854 7.16 13 7.802 13 9c0 1.202.853 1.845 1.577 1.925a.5.5 0 0 1 .423.493V13.5a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-2.082a.5.5 0 0 1 .423-.493C1.146 10.845 2 10.202 2 9c0-1.197-.854-1.838-1.577-1.919A.5.5 0 0 1 0 6.582V4.5z" />
                        </svg>
                    </span>
                    Cupones
                </a>
            </nav>

            <div class="adm-logout">
                <a href="@Url.Action("Logout", "Auth")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z" />
                        <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z" />
                    </svg>
                    Cerrar sesión
                </a>
            </div>

        </aside>

        <main class="adm-main">
            @if (TempData["Exito"] != null)
            {
                <div class="adm-alert success">✓ @TempData["Exito"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="adm-alert error">✕ @TempData["Error"]</div>
            }
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>