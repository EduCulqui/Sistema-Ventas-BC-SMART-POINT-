@model Sistema_BC_SMART_POINT.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-header">
            <span class="auth-logo">BC Smart Point</span>
            <h1 class="auth-title">Iniciar sesión</h1>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-bc-error" style="margin-bottom:1.25rem; border-radius:10px; padding:12px 16px;">
                @Html.ValidationSummary(false)
            </div>
        }

        <form method="post" asp-action="Login" class="auth-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="auth-field">
                <label asp-for="Email" class="auth-label">Correo electrónico</label>
                <input asp-for="Email" type="email" class="auth-input" placeholder="tu@correo.com" />
                <span asp-validation-for="Email" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Contrasenia" class="auth-label">Contraseña</label>
                <input asp-for="Contrasenia" type="password" class="auth-input" placeholder="••••••••" />
                <span asp-validation-for="Contrasenia" class="auth-error"></span>
            </div>

            <div class="auth-remember">
                <input asp-for="Recordarme" type="checkbox" id="Recordarme" class="auth-checkbox" />
                <label for="Recordarme" class="auth-remember-label">Recordarme</label>
            </div>

            <button type="submit" class="btn-bc btn-auth-bc">
                Iniciar sesión
            </button>
        </form>

        <div class="auth-footer">
            <a href="@Url.Action("Registro")" class="auth-link">
                ¿No tienes cuenta? <strong>Regístrate</strong>
            </a>
            <a href="@Url.Action("Index", "Catalogo")" class="detalle-volver">
                ← Volver al catálogo
            </a>
        </div>

    </div>
</div>


<style>
    /* login */
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 3rem 1rem 4rem;
    }

    .auth-card {
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 20px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
    }

    .auth-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        margin-bottom: 2rem;
        text-align: center;
    }

    .auth-logo {
        background: var(--bc-negro);
        color: var(--bc-amarillo);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        padding: 4px 14px;
        border-radius: 20px;
    }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--bc-texto-1);
        letter-spacing: -0.03em;
        margin: 0;
    }

    /* Campos */
    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
    }

    .auth-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .auth-label {
        font-size: 0.825rem;
        font-weight: 500;
        color: var(--bc-texto-1);
    }

    .auth-input {
        width: 100%;
        padding: 0.6rem 0.9rem;
        border: 1px solid var(--bc-borde);
        border-radius: 10px;
        font-size: 0.9rem;
        color: var(--bc-texto-1);
        background: var(--bc-fondo);
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
    }

    .auth-input:focus {
        border-color: var(--bc-amarillo);
        box-shadow: 0 0 0 3px rgba(245, 197, 0, 0.15);
        background: var(--bc-blanco);
    }

    .auth-input::placeholder {
        color: var(--bc-texto-2);
    }

    .auth-error {
        font-size: 0.75rem;
        color: #b91c1c;
    }

    /* Recordarme */
    .auth-remember {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .auth-checkbox {
        width: 16px;
        height: 16px;
        accent-color: var(--bc-amarillo);
        cursor: pointer;
    }

    .auth-remember-label {
        font-size: 0.85rem;
        color: var(--bc-texto-2);
        cursor: pointer;
    }

    /* Botón submit */
    .btn-auth-bc {
        width: 100%;
        text-align: center;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        border-radius: 12px;
        margin-top: 0.25rem;
        cursor: pointer;
    }

    /* Footer links */
    .auth-footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        margin-top: 1.75rem;
        text-align: center;
    }

    .auth-link {
        font-size: 0.875rem;
        color: var(--bc-texto-2);
        text-decoration: none;
        transition: color 0.2s;
    }

    .auth-link:hover {
        color: var(--bc-texto-1);
    }

    .auth-link strong {
        color: var(--bc-texto-1);
        font-weight: 600;
    }
</style>