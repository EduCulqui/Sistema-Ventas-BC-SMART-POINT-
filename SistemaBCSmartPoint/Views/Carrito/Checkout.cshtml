@model Sistema_BC_SMART_POINT.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    decimal descMonto = Model.Subtotal * (Model.DescuentoAplicado / 100m);
    decimal baseCalc = Model.Subtotal - descMonto;
    decimal igvCalc = Math.Round(baseCalc * 0.18m, 2);
    decimal totalCalc = baseCalc + igvCalc;
}

<div class="ck-wrap">

    <div class="ck-header">
        <h1>Finalizar compra</h1>
    </div>

    <div class="ck-steps">
        <div class="step active">
            <div class="step-dot">1</div>
            <span class="step-label">Datos y método</span>
        </div>
        <div class="step-line"></div>
        <div class="step next">
            <div class="step-dot">2</div>
            <span class="step-label">Pago</span>
        </div>
        <div class="step-line"></div>
        <div class="step next">
            <div class="step-dot">3</div>
            <span class="step-label">Confirmación</span>
        </div>
    </div>

    <form method="post" asp-action="ProcederPago">
        @Html.AntiForgeryToken()

        <div class="ck-grid">
            <div>
                <div class="ck-form-card">

                    <div class="ck-section">
                        <div class="ck-section-title">Dirección de envío</div>
                        <div class="ck-field">
                            <label asp-for="DireccionEnvio">Dirección</label>
                            <input asp-for="DireccionEnvio" placeholder="Av. Principal 123" />
                            <div class="field-error"><span asp-validation-for="DireccionEnvio"></span></div>
                        </div>
                        <div class="ck-grid-2">
                            <div class="ck-field">
                                <label asp-for="Ciudad">Ciudad</label>
                                <input asp-for="Ciudad" placeholder="Cajamarca" />
                                <div class="field-error"><span asp-validation-for="Ciudad"></span></div>
                            </div>
                            <div class="ck-field">
                                <label asp-for="CodigoPostal">Código postal</label>
                                <input asp-for="CodigoPostal" placeholder="06001" />
                            </div>
                        </div>
                    </div>

                    <div class="ck-section">
                        <div class="ck-section-title">Método de pago</div>
                        <div class="metodo-grid">
                            <div class="metodo-option">
                                <input type="radio" name="MetodoPago" id="m-yape" value="Yape" checked />
                                <label class="metodo-label" for="m-yape">
                                    <span class="metodo-icon">📱</span>
                                    Yape
                                </label>
                            </div>
                            <div class="metodo-option">
                                <input type="radio" name="MetodoPago" id="m-plin" value="Plin" />
                                <label class="metodo-label" for="m-plin">
                                    <span class="metodo-icon">📲</span>
                                    Plin
                                </label>
                            </div>
                            <div class="metodo-option">
                                <input type="radio" name="MetodoPago" id="m-trans" value="Transferencia" />
                                <label class="metodo-label" for="m-trans">
                                    <span class="metodo-icon">🏦</span>
                                    Transferencia
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="ck-section">
                        <div class="ck-section-title">Cupón de descuento (opcional)</div>
                        @if (TempData["ErrorCupon"] != null)
                        {
                            <div style="font-size:0.8rem; color:#b91c1c; margin-bottom:10px;">
                                @TempData["ErrorCupon"]
                            </div>
                        }
                        <div class="cupon-row">
                            <div class="ck-field" style="margin:0; flex:1;">
                                <label asp-for="CodigoCupon" class="visually-hidden">Código de cupón</label>
                                <input asp-for="CodigoCupon"
                                       placeholder="Ej: APPLE10"
                                       style="text-transform:uppercase;" />
                            </div>
                        </div>
                        @if (Model.DescuentoAplicado > 0)
                        {
                            <div class="cupon-ok">✓ @Model.DescuentoAplicado% de descuento aplicado</div>
                        }
                        <input type="hidden" asp-for="DescuentoAplicado" />
                    </div>

                </div>
            </div>

            <div class="ck-resumen">
                <h2>Tu pedido</h2>

                <div class="res-items">
                    @foreach (var item in Model.Items)
                    {
                        <div class="res-item">
                            <span class="ri-name">@item.Nombre</span>
                            <span class="ri-qty">×@item.Cantidad</span>
                            <span class="ri-price">S/ @item.SubTotal.ToString("0.00")</span>
                        </div>
                    }
                </div>

                <div class="res-row">
                    <span class="lbl">Subtotal</span>
                    <span class="val">S/ @Model.Subtotal.ToString("0.00")</span>
                </div>
                @if (Model.DescuentoAplicado > 0)
                {
                    <div class="res-row">
                        <span class="lbl">Descuento (@Model.DescuentoAplicado%)</span>
                        <span class="desc">− S/ @descMonto.ToString("0.00")</span>
                    </div>
                }
                <div class="res-row">
                    <span class="lbl">IGV (18%)</span>
                    <span class="val">S/ @igvCalc.ToString("0.00")</span>
                </div>

                <div class="res-total">
                    <span class="lbl">Total</span>
                    <span class="val"><span>S/</span>@totalCalc.ToString("0.00")</span>
                </div>

                <button type="submit" class="btn-siguiente">Continuar al pago →</button>

                <a href="@Url.Action("Index")" class="btn-volver-ck">← Editar carrito</a>
            </div>
        </div>
    </form>
</div>

<style>
    .ck-wrap {
        max-width: 1000px;
        margin: 2rem auto;
        padding: 0 1.25rem 3rem;
    }

    .ck-header {
        margin-bottom: 1.75rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--bc-borde);
    }

        .ck-header h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--bc-texto-1);
            margin: 0;
            letter-spacing: -0.02em;
        }

    .ck-steps {
        display: flex;
        align-items: center;
        margin-bottom: 2rem;
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }

    .step-dot {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        border: 2px solid var(--bc-borde);
        background: var(--bc-blanco);
        color: var(--bc-texto-2);
        transition: background 0.2s, border-color 0.2s;
    }

    .step.active .step-dot {
        background: var(--bc-negro);
        border-color: var(--bc-negro);
        color: var(--bc-amarillo);
    }

    .step.next .step-dot {
        background: var(--bc-fondo);
        border-color: var(--bc-borde);
        color: var(--bc-texto-2);
    }

    .step-label {
        font-size: 0.72rem;
        font-weight: 500;
        color: var(--bc-texto-2);
        white-space: nowrap;
    }

    .step.active .step-label {
        color: var(--bc-texto-1);
        font-weight: 600;
    }

    .step-line {
        flex: 1;
        height: 2px;
        background: var(--bc-borde);
        margin: 0 8px;
        margin-bottom: 20px;
    }

    .ck-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.5rem;
        align-items: start;
    }

    .ck-form-card {
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 16px;
        overflow: hidden;
    }

    .ck-section {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--bc-borde);
    }

        .ck-section:last-child {
            border-bottom: none;
        }

    .ck-section-title {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--bc-texto-2);
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 1rem;
    }

    .ck-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 1rem;
    }

        .ck-field:last-child {
            margin-bottom: 0;
        }

        .ck-field label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--bc-texto-1);
            letter-spacing: 0.01em;
        }

        .ck-field input[type="text"],
        .ck-field input[type="number"],
        .ck-field input[type="email"] {
            border: 1px solid var(--bc-borde);
            border-radius: 10px;
            padding: 0.55rem 0.85rem;
            font-size: 0.875rem;
            color: var(--bc-texto-1);
            background: var(--bc-fondo);
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            width: 100%;
            font-family: inherit;
        }

        .ck-field input:focus {
            border-color: var(--bc-amarillo);
            box-shadow: 0 0 0 3px rgba(245, 197, 0, 0.15);
            background: var(--bc-blanco);
        }

        .ck-field input::placeholder {
            color: var(--bc-texto-2);
        }

    .ck-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 1rem;
    }

    .field-error span {
        font-size: 0.75rem;
        color: #b91c1c;
    }

    .metodo-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .metodo-option input[type="radio"] {
        display: none;
    }

    .metodo-label {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        padding: 0.75rem 0.5rem;
        border: 1px solid var(--bc-borde);
        border-radius: 10px;
        cursor: pointer;
        font-size: 0.825rem;
        font-weight: 500;
        color: var(--bc-texto-2);
        background: var(--bc-fondo);
        transition: border-color 0.2s, color 0.2s, background 0.2s;
        text-align: center;
    }

        .metodo-label:hover {
            border-color: var(--bc-amarillo);
            color: var(--bc-texto-1);
        }

    .metodo-option input[type="radio"]:checked + .metodo-label {
        border-color: var(--bc-amarillo);
        background: var(--bc-blanco);
        color: var(--bc-texto-1);
        font-weight: 600;
        box-shadow: 0 0 0 2px rgba(245, 197, 0, 0.2);
    }

    .metodo-icon {
        font-size: 1.25rem;
    }

    .cupon-row {
        display: flex;
        gap: 8px;
        align-items: flex-end;
    }

    .cupon-ok {
        font-size: 0.8rem;
        font-weight: 500;
        color: #15803d;
        background: #f0fdf4;
        border: 1px solid #86efac;
        border-radius: 8px;
        padding: 6px 12px;
        margin-top: 8px;
    }

    .ck-resumen {
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 16px;
        padding: 1.5rem;
        position: sticky;
        top: 1.5rem;
    }

        .ck-resumen h2 {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--bc-texto-1);
            margin-bottom: 1rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--bc-borde);
        }

    .res-items {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 1rem;
    }

    .res-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.825rem;
    }

    .ri-name {
        flex: 1;
        font-weight: 500;
        color: var(--bc-texto-1);
    }

    .ri-qty {
        font-size: 0.75rem;
        color: var(--bc-texto-2);
    }

    .ri-price {
        font-weight: 600;
        color: var(--bc-texto-1);
        white-space: nowrap;
    }

    .res-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.875rem;
        color: var(--bc-texto-2);
        padding: 0.4rem 0;
        border-top: 1px solid var(--bc-borde);
    }

        .res-row .lbl {
            color: var(--bc-texto-2);
        }

        .res-row .val {
            font-weight: 500;
            color: var(--bc-texto-1);
        }

        .res-row .desc {
            font-weight: 500;
            color: #15803d;
        }

    .res-total {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 0.85rem 0 1rem;
        border-top: 1px solid var(--bc-borde);
        margin-top: 4px;
    }

        .res-total .lbl {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--bc-texto-1);
        }

        .res-total .val {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--bc-texto-1);
            letter-spacing: -0.02em;
        }

            .res-total .val span {
                font-size: 0.8rem;
                font-weight: 500;
                color: var(--bc-texto-2);
                margin-right: 2px;
            }

    .btn-siguiente {
        width: 100%;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--bc-negro);
        background: var(--bc-amarillo);
        border: none;
        border-radius: 10px;
        padding: 0.7rem 1rem;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
    }

        .btn-siguiente:hover {
            background: #e0b400;
            transform: translateY(-1px);
        }

    .btn-volver-ck {
        display: block;
        text-align: center;
        margin-top: 12px;
        font-size: 0.8rem;
        color: var(--bc-texto-2);
        text-decoration: none;
        transition: color 0.15s;
    }

        .btn-volver-ck:hover {
            color: var(--bc-texto-1);
        }

    @@media (max-width: 800px) {
        .ck-grid

    {
        grid-template-columns: 1fr;
    }

    .ck-resumen {
        position: static;
    }

    .metodo-grid {
        grid-template-columns: repeat(3, 1fr);
    }

    .ck-grid-2 {
        grid-template-columns: 1fr;
    }

    }

    @@media (max-width: 480px) {
        .metodo-grid

    {
        grid-template-columns: 1fr 1fr;
    }

    .ck-steps {
        gap: 0;
    }

    }
</style>