@model Sistema_BC_SMART_POINT.Models.Proveedor
@{
    ViewData["Title"] = "Editar proveedor";
    Layout = "_AdminLayout";
}

<div class="adm-page-header">
    <div>
        <h1>Editar proveedor</h1>
        <p>Modificando: <strong>@Model.NombreEmpresa</strong></p>
    </div>
    <a href="@Url.Action("Proveedores")" class="btn-adm-edit">← Volver</a>
</div>

<div class="adm-form-card">
    <form method="post" asp-action="EditarProveedor">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdProveedor" />
        <div class="adm-form-grid-2">
            <div class="adm-field">
                <label asp-for="NombreEmpresa">Nombre de la empresa</label>
                <input asp-for="NombreEmpresa" />
                <div class="field-error"><span asp-validation-for="NombreEmpresa"></span></div>
            </div>
            <div class="adm-field">
                <label asp-for="ContactoNombre">Nombre del contacto</label>
                <input asp-for="ContactoNombre" />
                <div class="field-error"><span asp-validation-for="ContactoNombre"></span></div>
            </div>
            <div class="adm-field">
                <label asp-for="Celular">Celular</label>
                <input asp-for="Celular" />
                <div class="field-error"><span asp-validation-for="Celular"></span></div>
            </div>
            <div class="adm-field">
                <label asp-for="Email">Correo electrónico</label>
                <input asp-for="Email" type="email" />
                <div class="field-error"><span asp-validation-for="Email"></span></div>
            </div>
            <div class="adm-field">
                <label asp-for="Ruc">RUC</label>
                <input asp-for="Ruc" />
                <div class="field-error"><span asp-validation-for="Ruc"></span></div>
            </div>
            <div class="adm-field">
                <label>Estado</label>
                <div class="adm-check" style="margin-top:10px;">
                    <input asp-for="Estado" type="checkbox" />
                    <label asp-for="Estado">Proveedor activo</label>
                </div>
            </div>
        </div>
        <div class="adm-field">
            <label asp-for="Direccion">Dirección</label>
            <input asp-for="Direccion" />
            <div class="field-error"><span asp-validation-for="Direccion"></span></div>
        </div>
        <div class="adm-form-footer">
            <button type="submit" class="btn-adm-primary">Guardar cambios</button>
            <a href="@Url.Action("Proveedores")" class="btn-adm-edit">Cancelar</a>
        </div>
    </form>
</div>


<style>
    .adm-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--bc-borde);
    }

        .adm-page-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--bc-texto-1);
            margin: 0 0 4px;
            letter-spacing: -0.02em;
        }

        .adm-page-header p {
            font-size: 0.825rem;
            color: var(--bc-texto-2);
            margin: 0;
        }

        .adm-page-header strong {
            color: var(--bc-texto-1);
            font-weight: 600;
        }

    .adm-form-card {
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 16px;
        padding: 2rem;
        max-width: 660px;
    }

    .adm-form-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 1.25rem;
    }

    .adm-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 1.1rem;
    }

        .adm-field label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--bc-texto-1);
            letter-spacing: 0.01em;
        }

        .adm-field input[type="text"],
        .adm-field input[type="email"] {
            border: 1px solid var(--bc-borde);
            border-radius: 10px;
            padding: 0.55rem 0.85rem;
            font-size: 0.875rem;
            color: var(--bc-texto-1);
            background: var(--bc-fondo);
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            width: 100%;
            font-family: inherit;
        }

        .adm-field input:focus {
            border-color: var(--bc-amarillo);
            box-shadow: 0 0 0 3px rgba(245, 197, 0, 0.15);
            background: var(--bc-blanco);
        }

        .adm-field input::placeholder {
            color: var(--bc-texto-2);
        }

    .field-error {
        min-height: 16px;
    }

        .field-error span {
            font-size: 0.75rem;
            color: #b91c1c;
        }

    .adm-check {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }

        .adm-check input[type="checkbox"] {
            width: 17px;
            height: 17px;
            accent-color: var(--bc-amarillo);
            cursor: pointer;
            flex-shrink: 0;
        }

        .adm-check label {
            font-size: 0.875rem;
            color: var(--bc-texto-1);
            cursor: pointer;
            margin: 0;
            font-weight: 400;
        }

    .adm-form-footer {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-top: 1.25rem;
        border-top: 1px solid var(--bc-borde);
        margin-top: 0.25rem;
    }

    .btn-adm-primary {
        display: inline-flex;
        align-items: center;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--bc-negro);
        background: var(--bc-amarillo);
        border: none;
        border-radius: 10px;
        padding: 0.55rem 1.35rem;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
        text-decoration: none;
    }

        .btn-adm-primary:hover {
            background: #e0b400;
            transform: translateY(-1px);
        }

        .btn-adm-primary:active {
            transform: translateY(0);
        }

    .btn-adm-edit {
        display: inline-flex;
        align-items: center;
        font-size: 0.825rem;
        font-weight: 500;
        color: var(--bc-texto-2);
        background: transparent;
        border: 1px solid var(--bc-borde);
        border-radius: 10px;
        padding: 0.55rem 1.1rem;
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s;
    }

        .btn-adm-edit:hover {
            color: var(--bc-texto-1);
            border-color: var(--bc-texto-2);
        }

    @@media (max-width: 640px) {
        .adm-form-grid-2

    {
        grid-template-columns: 1fr;
    }

    .adm-page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }

    }
</style>
