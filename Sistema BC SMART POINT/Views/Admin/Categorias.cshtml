@model IEnumerable<Sistema_BC_SMART_POINT.Models.Categoria>
@{
    ViewData["Title"] = "Categorías";
    Layout = "_AdminLayout";
}

<div class="adm-page-header">
    <div>
        <h1>Categorías</h1>
        <p>@Model.Count(c => c.Estado) activas · @Model.Count(c => !c.Estado) inactivas</p>
    </div>
    <a href="@Url.Action("CrearCategoria")" class="btn-adm-primary">+ Nueva categoría</a>
</div>

<div class="adm-card">
    <div class="adm-card-header">
        <h2>Listado de categorías</h2>
    </div>
    <table class="adm-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td style="color:#9ca3af;">@c.IdCategoria</td>
                    <td style="font-weight:600;">@c.NomCategoria</td>
                    <td style="color:#6b7280; max-width:300px;">@c.Descripcion</td>
                    <td>
                        @if (c.Estado)
                        {
                            <span class="badge-activo">Activa</span>
                        }
                        else
                        {
                            <span class="badge-inactivo">Inactiva</span>
                        }
                    </td>
                    <td>
                        <div style="display:flex; gap:8px;">
                            <a href="@Url.Action("EditarCategoria", new { id = c.IdCategoria })"
                               class="btn-adm-edit">Editar</a>
                            @if (c.Estado)
                            {
                                <form method="post" asp-action="EliminarCategoria"
                                      onsubmit="return confirm('¿Desactivar esta categoría?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.IdCategoria" />
                                    <button type="submit" class="btn-adm-delete">Desactivar</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-action="ActivarCategoria"
                                      onsubmit="return confirm('¿Activar esta categoría?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.IdCategoria" />
                                    <button type="submit" class="btn-adm-activate">Activar</button>
                                </form>
                            }
                            <form method="post" asp-action="EliminarCategoriaDefinitivo"
                                  onsubmit="return confirm('¿Eliminar permanentemente esta categoría? Esta acción no se puede deshacer.')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.IdCategoria" />
                                <button type="submit" class="btn-adm-destroy">Eliminar</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .adm-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--bc-borde);
    }

        .adm-page-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--bc-texto-1);
            margin: 0 0 4px;
            letter-spacing: -0.02em;
        }

        .adm-page-header p {
            font-size: 0.825rem;
            color: var(--bc-texto-2);
            margin: 0;
        }

    .btn-adm-primary {
        display: inline-flex;
        align-items: center;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--bc-negro);
        background: var(--bc-amarillo);
        border: none;
        border-radius: 10px;
        padding: 0.55rem 1.35rem;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
        text-decoration: none;
        white-space: nowrap;
    }

        .btn-adm-primary:hover {
            background: #e0b400;
            transform: translateY(-1px);
        }

        .btn-adm-primary:active {
            transform: translateY(0);
        }

    .adm-card {
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 16px;
        overflow: hidden;
    }

    .adm-card-header {
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--bc-borde);
    }

        .adm-card-header h2 {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--bc-texto-1);
            margin: 0;
        }

    .adm-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

        .adm-table thead tr {
            background: var(--bc-fondo);
        }

        .adm-table th {
            padding: 0.75rem 1.25rem;
            text-align: left;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--bc-texto-2);
            text-transform: uppercase;
            letter-spacing: 0.07em;
            border-bottom: 1px solid var(--bc-borde);
            white-space: nowrap;
        }

        .adm-table td {
            padding: 0.85rem 1.25rem;
            border-bottom: 1px solid var(--bc-borde);
            color: var(--bc-texto-1);
            vertical-align: middle;
        }

        .adm-table tbody tr:last-child td {
            border-bottom: none;
        }

        .adm-table tbody tr:hover {
            background: var(--bc-fondo);
        }

        .adm-table td[style*="max-width"] {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .badge-activo,
    .badge-inactivo {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        letter-spacing: 0.02em;
    }

    .badge-activo {
        background: #f0fdf4;
        color: #15803d;
    }

    .badge-inactivo {
        background: #fff1f2;
        color: #b91c1c;
    }

    .btn-adm-edit {
        display: inline-flex;
        align-items: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--bc-texto-2);
        background: transparent;
        border: 1px solid var(--bc-borde);
        border-radius: 8px;
        padding: 0.35rem 0.85rem;
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s;
        white-space: nowrap;
    }

        .btn-adm-edit:hover {
            color: var(--bc-texto-1);
            border-color: var(--bc-texto-2);
        }

    .btn-adm-delete {
        display: inline-flex;
        align-items: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: #b91c1c;
        background: transparent;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        padding: 0.35rem 0.85rem;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
    }

        .btn-adm-delete:hover {
            background: #fff1f2;
            border-color: #b91c1c;
        }

    @@media (max-width: 700px) {
        .adm-page-header

    {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }

    .adm-table th,
    .adm-table td {
        padding: 0.65rem 0.75rem;
    }

    }

    .btn-adm-destroy {
        display: inline-flex;
        align-items: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--bc-blanco);
        background: #b91c1c;
        border: 1px solid #b91c1c;
        border-radius: 8px;
        padding: 0.35rem 0.85rem;
        cursor: pointer;
        transition: background 0.15s;
        white-space: nowrap;
    }

    .btn-adm-destroy:hover {
        background: #991b1b;
        border-color: #991b1b;
    }

    .btn-adm-activate {
        display: inline-flex;
        align-items: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: #15803d;
        background: transparent;
        border: 1px solid #86efac;
        border-radius: 8px;
        padding: 0.35rem 0.85rem;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
    }

    .btn-adm-activate:hover {
        background: #f0fdf4;
        border-color: #15803d;
    }
</style>