<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BC Smart Point</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sistema_BC_SMART_POINT.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-bc border-bottom mb-3">
            <div class="container">

                <a class="navbar-brand-bc fw-semibold" asp-controller="Home" asp-action="Index">
                    BC Smart Point
                </a>

                <button class="navbar-toggler navbar-toggler-bc" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link-bc" asp-controller="Catalogo" asp-action="Index">
                                Catálogo
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center gap-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-user-bc">
                                    Hola, @User.Identity.Name.Split(' ')[0]
                                </span>
                            </li>

                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link-bc" asp-controller="Admin" asp-action="Dashboard">
                                        Panel Admin
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link-bc nav-carrito-bc" asp-controller="Carrito" asp-action="Index">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                             fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4z" />
                                        </svg>
                                        Carrito
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="btn-bc-outline btn-sm-bc"
                                   asp-controller="Auth" asp-action="Logout">
                                    Cerrar sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn-bc btn-sm-bc ms-2"
                                   asp-controller="Auth" asp-action="Login">
                                    Iniciar sesión
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">

            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-bc-exito alert-dismissible fade show" role="alert">
                    @TempData["Exito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-bc-error alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="footer-bc">
        <div class="container">
            &copy; 2026 - BC Smart Point
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<style>
    /* Variables  */
    :root {
        --bc-negro: #1A1A1A;
        --bc-negro-hover: #2E2E2E;
        --bc-amarillo: #F5C500;
        --bc-amarillo-hover: #FFDA44;
        --bc-fondo: #F5F5F7;
        --bc-blanco: #FFFFFF;
        --bc-texto-1: #1D1D1F;
        --bc-texto-2: #6E6E73;
        --bc-borde: #D2D2D7;
    }

    /* Body */
    body {
        background-color: var(--bc-fondo);
        color: var(--bc-texto-1);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* Navbar */
    .navbar-bc {
        background-color: var(--bc-negro);
        border-bottom: 1px solid #2E2E2E !important;
        padding: 0.75rem 0;
    }

    .navbar-brand-bc {
        color: var(--bc-amarillo) !important;
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        text-decoration: none;
        transition: color 0.2s;
    }

        .navbar-brand-bc:hover {
            color: var(--bc-amarillo-hover) !important;
        }

    .nav-link-bc {
        color: #E5E5E5 !important;
        font-size: 0.9rem;
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        text-decoration: none;
        transition: background-color 0.2s, color 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .nav-link-bc:hover {
            background-color: var(--bc-negro-hover);
            color: var(--bc-amarillo) !important;
        }

    .nav-user-bc {
        color: var(--bc-texto-2);
        font-size: 0.875rem;
        padding: 0.4rem 0.5rem;
        cursor: default;
    }

    .navbar-toggler-bc {
        border-color: #3a3a3a;
    }

    /* Botones  */
    .btn-bc {
        background-color: var(--bc-amarillo);
        color: var(--bc-negro) !important;
        font-weight: 600;
        border: none;
        border-radius: 20px;
        text-decoration: none;
        transition: background-color 0.2s, transform 0.1s;
        display: inline-block;
    }

        .btn-bc:hover {
            background-color: var(--bc-amarillo-hover);
            color: var(--bc-negro) !important;
            transform: translateY(-1px);
        }

        .btn-bc:active {
            transform: translateY(0);
        }

    .btn-bc-outline {
        background-color: transparent;
        color: #E5E5E5 !important;
        border: 1px solid #3a3a3a;
        border-radius: 20px;
        text-decoration: none;
        transition: border-color 0.2s, color 0.2s, background-color 0.2s;
        display: inline-block;
    }

        .btn-bc-outline:hover {
            border-color: var(--bc-amarillo);
            color: var(--bc-amarillo) !important;
            background-color: rgba(245, 197, 0, 0.08);
        }

    .btn-sm-bc {
        font-size: 0.82rem;
        padding: 0.35rem 1rem;
    }

    /* Alertas  */
    .alert-bc-exito {
        background-color: #f0fdf4;
        border: 1px solid #86efac;
        color: #15803d;
        border-radius: 10px;
    }

    .alert-bc-error {
        background-color: #fff1f2;
        border: 1px solid #fca5a5;
        color: #b91c1c;
        border-radius: 10px;
    }

    /* Footer */
    .footer-bc {
        text-align: center;
        background-color: var(--bc-negro);
        border-top: 1px solid #2E2E2E;
        color: var(--bc-texto-2);
        font-size: 0.85rem;
        padding: 1.25rem 0;
        margin-top: 3rem;
    }
</style>
