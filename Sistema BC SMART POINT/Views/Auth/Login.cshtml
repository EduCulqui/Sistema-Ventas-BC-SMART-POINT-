@model Sistema_BC_SMART_POINT.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<h2>Iniciar sesión</h2>

@if (!ViewData.ModelState.IsValid)
{
    <p style="color:red">@Html.ValidationSummary()</p>
}

<form method="post" asp-action="Login">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ReturnUrl" />

    <div>
        <label asp-for="Email">Correo</label>
        <input asp-for="Email" type="email" />
        <span asp-validation-for="Email" style="color:red"></span>
    </div>

    <div>
        <label asp-for="Contrasenia">Contraseña</label>
        <input asp-for="Contrasenia" type="password" />
        <span asp-validation-for="Contrasenia" style="color:red"></span>
    </div>

    <div>
        <input asp-for="Recordarme" type="checkbox" />
        <label asp-for="Recordarme">Recordarme</label>
    </div>

    <button type="submit">Iniciar sesión</button>
</form>

<p><a href="@Url.Action("Registro")">¿No tienes cuenta? Regístrate</a></p>
<p><a href="@Url.Action("Index", "Catalogo")">← Volver al catálogo</a></p>