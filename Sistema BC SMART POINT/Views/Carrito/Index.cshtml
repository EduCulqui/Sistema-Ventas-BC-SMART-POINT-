@model List<Sistema_BC_SMART_POINT.Models.ViewModels.CarritoItemViewModel>
@{
    ViewData["Title"] = "Mi carrito";
    var subtotal = Model.Sum(i => i.SubTotal);
    var igv = Math.Round(subtotal * 0.18m, 2);
    var total = subtotal + igv;
}

<div class="carrito-bc">

    <div class="carrito-items-col">

        <div class="catalog-header">
            <h2 class="catalog-title">Mi carrito</h2>
            <span class="catalog-count">@Model.Sum(i => i.Cantidad) producto(s)</span>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4z" />
                </svg>
                <p>Tu carrito está vacío</p>
                <a href="@Url.Action("Index", "Catalogo")" class="btn-bc btn-sm-bc">
                    Explorar catálogo
                </a>
            </div>
        }
        else
        {
            <div class="carrito-list">
                @foreach (var item in Model)
                {
                    <div class="carrito-item">

                        <div class="carrito-item-img">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" alt="@item.Nombre" />
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5 1a2 2 0 0 0-2 2v1H1.5A1.5 1.5 0 0 0 0 5.5v9A1.5 1.5 0 0 0 1.5 16h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 4H13V3a2 2 0 0 0-2-2H5zm3 10.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z" />
                                </svg>
                            }
                </div>

                <div class="carrito-item-info">
                    <p class="carrito-item-nombre">@item.Nombre</p>
                    <p class="carrito-item-meta">
                        @string.Join(" · ", new[] { item.Color, item.Capacidad }
                                                .Where(s => !string.IsNullOrEmpty(s)))
                    </p>
                    <p class="carrito-item-precio">
                        S/ @item.PrecioUnitario.ToString("0.00") × @item.Cantidad
                    </p>
                </div>

                <div class="carrito-item-right">
                    <span class="carrito-item-subtotal">
                        S/ @item.SubTotal.ToString("0.00")
                    </span>
                    <form method="post" asp-action="Quitar">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productoId" value="@item.ProductoId" />
                        <button type="submit" class="btn-quitar-bc">Quitar</button>
                    </form>
                </div>

            </div>
                        }
            </div>
        }

        <a href="@Url.Action("Index", "Catalogo")" class="detalle-volver">
            ← Seguir comprando
        </a>

    </div>

    <div class="resumen-bc">
        <h3 class="resumen-title-bc">Resumen del pedido</h3>

        <div class="resumen-row-bc">
            <span>Subtotal (@Model.Sum(i => i.Cantidad) ítems)</span>
            <span>S/ @subtotal.ToString("0.00")</span>
        </div>
        <div class="resumen-row-bc">
            <span>IGV (18%)</span>
            <span>S/ @igv.ToString("0.00")</span>
        </div>

        <div class="resumen-divider-bc"></div>

        <div class="resumen-row-bc resumen-total-bc">
            <span>Total</span>
            <span>S/ @total.ToString("0.00")</span>
        </div>

        <p class="resumen-note-bc">Incluye impuestos. El envío se calcula en el siguiente paso.</p>

        @if (Model.Any())
        {
            <a href="@Url.Action("Checkout", "Carrito")" class="btn-bc btn-checkout-bc">
                Continuar al pago →
            </a>
        }
        else
        {
            <span class="btn-bc btn-checkout-bc btn-bc-disabled">
                Continuar al pago →
            </span>
        }
    </div>

</div>

<style>
    /*  Carrito layout  */
    .carrito-bc {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 2rem;
        align-items: start;
        padding: 1rem 0 3rem;
    }


    {
        grid-template-columns: 1fr;
    }

    /* Lista de items  */
    .carrito-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 1.25rem;
    }

    .carrito-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 14px;
        padding: 1rem 1.25rem;
        transition: border-color 0.2s;
    }

        .carrito-item:hover {
            border-color: var(--bc-amarillo);
        }

    .carrito-item-img {
        width: 72px;
        height: 72px;
        min-width: 72px;
        background: var(--bc-fondo);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        color: var(--bc-texto-2);
    }

        .carrito-item-img img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 6px;
        }

    .carrito-item-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .carrito-item-nombre {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--bc-texto-1);
        margin: 0;
    }

    .carrito-item-meta {
        font-size: 0.8rem;
        color: var(--bc-texto-2);
        margin: 0;
    }

    .carrito-item-precio {
        font-size: 0.82rem;
        color: var(--bc-texto-2);
        margin: 0;
    }

    .carrito-item-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
        min-width: 100px;
    }

    .carrito-item-subtotal {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--bc-texto-1);
        letter-spacing: -0.02em;
    }

    .btn-quitar-bc {
        background: transparent;
        border: none;
        font-size: 0.78rem;
        color: var(--bc-texto-2);
        cursor: pointer;
        padding: 0;
        text-decoration: underline;
        transition: color 0.2s;
    }

        .btn-quitar-bc:hover {
            color: #b91c1c;
        }

    /* Resumen  */
    .resumen-bc {
        background: var(--bc-blanco);
        border: 1px solid var(--bc-borde);
        border-radius: 16px;
        padding: 1.5rem;
        position: sticky;
        top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .resumen-title-bc {
        font-size: 1rem;
        font-weight: 600;
        color: var(--bc-texto-1);
        margin: 0 0 0.25rem;
    }

    .resumen-row-bc {
        display: flex;
        justify-content: space-between;
        font-size: 0.875rem;
        color: var(--bc-texto-2);
    }

    .resumen-divider-bc {
        border-top: 1px solid var(--bc-borde);
        margin: 0.25rem 0;
    }

    .resumen-total-bc {
        font-size: 1rem;
        font-weight: 700;
        color: var(--bc-texto-1);
    }

    .resumen-note-bc {
        font-size: 0.75rem;
        color: var(--bc-texto-2);
        margin: 0;
        line-height: 1.5;
    }

    .btn-checkout-bc {
        width: 100%;
        text-align: center;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        border-radius: 12px;
        margin-top: 0.25rem;
    }
</style>