@model List<Sistema_BC_SMART_POINT.Models.ViewModels.CarritoItemViewModel>

@{
    ViewData["Title"] = "Mi carrito";
    var subtotal = Model.Sum(i => i.SubTotal);
    var igv = Math.Round(subtotal * 0.18m, 2);
    var total = subtotal + igv;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Carrito – BC SMART POINT</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #F5F3EE;
            --surface: #fff;
            --ink: #1A1A18;
            --ink-2: #5C5C57;
            --ink-3: #9C9C96;
            --accent: #D85A30;
            --accent-light: #FAECE7;
            --accent-dark: #993C1D;
            --border: rgba(26,26,24,.10);
            --border-h: rgba(26,26,24,.22);
            --radius: 16px;
            --radius-sm: 10px;
            --fd: 'Syne', sans-serif;
            --fb: 'DM Sans', sans-serif;
        }

        body {
            background: var(--bg);
            color: var(--ink);
            font-family: var(--fb);
            font-size: 15px;
        }

        /* HEADER */
        .site-header {
            background: var(--ink);
            padding: 1.25rem 2.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .brand {
            font-family: var(--fd);
            font-size: 1.1rem;
            font-weight: 800;
            color: #fff;
            text-decoration: none;
            letter-spacing: -.02em;
        }

            .brand span {
                color: var(--accent);
            }

        .header-cart {
            font-size: .82rem;
            color: rgba(255,255,255,.5);
        }

        /* BREADCRUMB */
        .breadcrumb {
            padding: 1rem 2.5rem;
            display: flex;
            gap: .5rem;
            align-items: center;
            font-size: .8rem;
            color: var(--ink-3);
        }

            .breadcrumb a {
                color: var(--ink-2);
                text-decoration: none;
            }

                .breadcrumb a:hover {
                    color: var(--accent);
                }

        /* LAYOUT */
        .page-layout {
            margin: 0 2.5rem 4rem;
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 2rem;
            align-items: start;
        }

        /* ALERTAS */
        .alert {
            border-radius: var(--radius-sm);
            padding: .75rem 1rem;
            font-size: .85rem;
            margin-bottom: 1.25rem;
        }

        .alert-ok {
            background: #EAF3DE;
            color: #3B6D11;
            border: 1px solid rgba(59,109,17,.2);
        }

        .alert-err {
            background: var(--accent-light);
            color: var(--accent-dark);
            border: 1px solid rgba(216,90,48,.2);
        }

        /* TITLE */
        .section-title {
            font-family: var(--fd);
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: -.03em;
            margin-bottom: 1.25rem;
        }

        /* TABLA DE ITEMS */
        .items-list {
            display: flex;
            flex-direction: column;
            gap: .75rem;
        }

        .item-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.25rem;
            display: grid;
            grid-template-columns: 64px 1fr auto;
            gap: 1rem;
            align-items: center;
            transition: border-color .15s;
        }

            .item-card:hover {
                border-color: var(--border-h);
            }

        .item-img {
            width: 64px;
            height: 64px;
            border-radius: 10px;
            background: var(--accent-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            overflow: hidden;
            flex-shrink: 0;
        }

            .item-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .item-info {
            display: flex;
            flex-direction: column;
            gap: .2rem;
        }

        .item-nombre {
            font-family: var(--fd);
            font-size: .95rem;
            font-weight: 700;
            line-height: 1.2;
        }

        .item-meta {
            font-size: .78rem;
            color: var(--ink-3);
        }

        .item-precio {
            font-size: .88rem;
            color: var(--ink-2);
            margin-top: .2rem;
        }

        .item-right {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: .6rem;
        }

        .item-subtotal {
            font-family: var(--fd);
            font-size: 1.05rem;
            font-weight: 800;
            color: var(--ink);
        }

        .btn-quitar {
            font-family: var(--fb);
            font-size: .75rem;
            color: var(--ink-3);
            background: none;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: .25rem .6rem;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-quitar:hover {
                border-color: var(--accent);
                color: var(--accent);
            }

        /* EMPTY */
        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: .75rem;
            padding: 4rem 2rem;
            color: var(--ink-3);
        }

            .empty-state .icon {
                font-size: 3rem;
                opacity: .3;
            }

            .empty-state a {
                color: var(--accent);
                text-decoration: underline;
                font-size: .9rem;
            }

        /* RESUMEN */
        .resumen-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.5rem;
            position: sticky;
            top: 1.5rem;
        }

        .resumen-title {
            font-family: var(--fd);
            font-size: 1rem;
            font-weight: 800;
            margin-bottom: 1.25rem;
            letter-spacing: -.01em;
        }

        .resumen-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: .55rem 0;
            border-bottom: 1px solid var(--border);
            font-size: .88rem;
        }

            .resumen-row:last-of-type {
                border-bottom: none;
            }

            .resumen-row .label {
                color: var(--ink-2);
            }

            .resumen-row.total .label {
                font-weight: 700;
                color: var(--ink);
                font-size: .95rem;
            }

            .resumen-row.total .value {
                font-family: var(--fd);
                font-size: 1.3rem;
                font-weight: 800;
                color: var(--accent);
            }

        .igv-note {
            font-size: .72rem;
            color: var(--ink-3);
            margin-top: .5rem;
            margin-bottom: 1.25rem;
        }

        .btn-checkout {
            display: block;
            width: 100%;
            text-align: center;
            font-family: var(--fb);
            font-size: .95rem;
            font-weight: 500;
            background: var(--ink);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: .8rem;
            cursor: pointer;
            text-decoration: none;
            transition: background .15s;
        }

            .btn-checkout:hover {
                background: #2e2e2b;
            }

        .btn-seguir {
            display: block;
            text-align: center;
            font-size: .82rem;
            color: var(--ink-3);
            margin-top: .85rem;
            text-decoration: none;
        }

            .btn-seguir:hover {
                color: var(--accent);
            }

        {
            grid-template-columns: 1fr;
            margin: 0 1rem 3rem;
        }

        .site-header, .breadcrumb {
            padding-left: 1rem;
            padding-right: 1rem;
        }

        .resumen-card {
            position: static;
        }

        }
    </style>
</head>
<body>

    <header class="site-header">
        <a href="@Url.Action("Index", "Catalogo")" class="brand">BC <span>SMART</span> POINT</a>
        <span class="header-cart">@Model.Sum(i => i.Cantidad) producto(s) en carrito</span>
    </header>

    <nav class="breadcrumb">
        <a href="@Url.Action("Index", "Catalogo")">Catálogo</a>
        <span>›</span>
        <span>Mi carrito</span>
    </nav>

    <div class="page-layout">
        <!-- ITEMS -->
        <div>
            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-ok">@TempData["Exito"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-err">@TempData["Error"]</div>
            }

            <h1 class="section-title">Mi carrito</h1>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div class="icon">🛒</div>
                    <strong>Tu carrito está vacío</strong>
                    <a href="@Url.Action("Index", "Catalogo")">Explorar catálogo</a>
                </div>
            }
            else
            {
                <div class="items-list">
                    @foreach (var item in Model)
                    {
                        <div class="item-card">
                            <div class="item-img">
                                @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                {
                                    <img src="@item.ImagenUrl" alt="@item.Nombre" />
                                }
                                else
                                {

                                    <span>📦</span>
                                }
                            </div>
                            <div class="item-info">
                                <div class="item-nombre">@item.Nombre</div>
                                <div class="item-meta">
                                    @if (!string.IsNullOrEmpty(item.Color))
                                    {
                                        <span>@item.Color</span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Capacidad))
                                    {
                                        <span> · @item.Capacidad</span>
                                    }
                                    <span> · Cant: @item.Cantidad</span>
                                </div>
                                <div class="item-precio">S/ @item.PrecioUnitario.ToString("0.00") c/u</div>
                            </div>
                            <div class="item-right">
                                <span class="item-subtotal">S/ @item.SubTotal.ToString("0.00")</span>
                                <form method="post" asp-action="Quitar">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productoId" value="@item.ProductoId" />
                                    <button type="submit" class="btn-quitar">Quitar</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- RESUMEN -->
        <div class="resumen-card">
            <div class="resumen-title">Resumen del pedido</div>
            <div class="resumen-row">
                <span class="label">Subtotal (@Model.Sum(i => i.Cantidad) ítems)</span>
                <span>S/ @subtotal.ToString("0.00")</span>
            </div>
            <div class="resumen-row">
                <span class="label">IGV (18%)</span>
                <span>S/ @igv.ToString("0.00")</span>
            </div>
            <div class="resumen-row total">
                <span class="label">Total</span>
                <span class="value">S/ @total.ToString("0.00")</span>
            </div>
            <p class="igv-note">Incluye impuestos. El envío se calcula en el siguiente paso.</p>

            @if (Model.Any())
            {
                <a href="@Url.Action("Checkout")" class="btn-checkout">Continuar al pago →</a>
            }
            else
            {
                <span class="btn-checkout" style="opacity:.4;cursor:default;">Continuar al pago →</span>
            }
            <a href="@Url.Action("Index", "Catalogo")" class="btn-seguir">← Seguir comprando</a>
        </div>
    </div>

</body>
</html>

