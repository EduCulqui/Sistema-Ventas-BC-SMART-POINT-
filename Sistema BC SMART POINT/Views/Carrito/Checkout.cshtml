@model Sistema_BC_SMART_POINT.Models.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
    decimal descPct = decimal.TryParse(TempData["DescuentoPct"]?.ToString(), out var dp) ? dp : 0;
    string cuponCode = TempData["CodigoCupon"]?.ToString() ?? "";
    decimal descMonto = Math.Round(Model.Subtotal * (descPct / 100), 2);
    decimal totalFinal = Model.Total - descMonto;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout – BC SMART POINT</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

    <header class="site-header">
        <a href="@Url.Action("Index", "Catalogo")" class="brand">BC <span>SMART</span> POINT</a>
    </header>

    <nav class="breadcrumb">
        <a href="@Url.Action("Index", "Catalogo")">Catálogo</a>
        <span>›</span>
        <a href="@Url.Action("Index", "Carrito")">Carrito</a>
        <span>›</span>
        <span>Checkout</span>
    </nav>

    <div class="page-layout">
        <!-- FORMULARIO -->
        <div>
            @if (TempData["ExitoCupon"] != null)
            {
                <div class="alert alert-ok">@TempData["ExitoCupon"]</div>
            }
            @if (TempData["ErrorCupon"] != null)
            {
                <div class="alert alert-err">@TempData["ErrorCupon"]</div>
            }

            <form method="post" asp-action="ConfirmarPedido">
                @Html.AntiForgeryToken()

                @* Pasar cupón activo si existe *@
                @if (!string.IsNullOrEmpty(cuponCode))
                {
                    <input type="hidden" name="CodigoCupon" value="@cuponCode" />
                    <input type="hidden" name="DescuentoPct" value="@descPct" />
                }

                <!-- Datos de envío -->
                <div class="form-card">
                    <h2>Datos de envío</h2>
                    <div class="field-grid">
                        <div class="field field-full">
                            <label asp-for="DireccionEnvio">Dirección</label>
                            <input asp-for="DireccionEnvio" placeholder="Av. Principal 123, Cajamarca" />
                            <span class="val-msg"><partial name="~/Views/Shared/_ValidationMsg.cshtml" for="DireccionEnvio" /></span>
                        </div>
                        <div class="field">
                            <label asp-for="Ciudad">Ciudad</label>
                            <input asp-for="Ciudad" placeholder="Cajamarca" />
                        </div>
                        <div class="field">
                            <label asp-for="DireccionEnvio">Departamento</label>
                            <input asp-for="Ciudad" placeholder="Cajamarca" />
                        </div>
                        
                    </div>
                </div>

                <!-- Método de pago -->
                <div class="form-card">
                    <h2>Método de pago</h2>
                    <div class="field">
                        <label asp-for="MetodoPago">Selecciona un método</label>
                        <select asp-for="MetodoPago">
                            <option value="">— Seleccionar —</option>
                            <option value="Efectivo">Efectivo contra entrega</option>
                            <option value="Transferencia">Transferencia bancaria</option>
                            <option value="Yape">Yape</option>
                            <option value="Plin">Plin</option>
                            <option value="Tarjeta">Tarjeta (POS)</option>
                        </select>
                    </div>
                </div>

                <!-- Botón submit (oculto, se activa desde el resumen) -->
                <button type="submit" id="btnSubmit" style="display:none">Confirmar</button>
            </form>

            <!-- Cupón (form separado para no mezclar con el pedido) -->
            <div class="form-card">
                <h2>¿Tienes un cupón?</h2>
                <form method="post" asp-action="AplicarCupon">
                    @Html.AntiForgeryToken()
                    <div class="cupon-row">
                        <div class="field">
                            <label for="codigo">Código de cupón</label>
                            <input id="codigo" name="codigo" type="text" placeholder="Ej: APPLE10" />
                        </div>
                        <button type="submit" class="btn-cupon">Aplicar</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- RESUMEN LATERAL -->
        <div class="resumen-card">
            <div class="resumen-title">Tu pedido</div>

            <div class="mini-items">
                @foreach (var item in Model.Items)
                {
                    <div class="mini-item">
                        <span class="mname">@item.Nombre <span style="color:var(--ink-3)">×@item.Cantidad</span></span>
                        <span class="mprice">S/ @item.SubTotal.ToString("0.00")</span>
                    </div>
                }
            </div>

            <hr class="divider" />

            <div class="resumen-row">
                <span class="label">Subtotal</span>
                <span>S/ @Model.Subtotal.ToString("0.00")</span>
            </div>
            <div class="resumen-row">
                <span class="label">IGV (18%)</span>
                <span>S/ @Model.IGV.ToString("0.00")</span>
            </div>
            @if (descPct > 0)
            {
                <div class="resumen-row descuento">
                    <span class="label">Cupón @cuponCode (@descPct%)</span>
                    <span class="value">− S/ @descMonto.ToString("0.00")</span>
                </div>
            }
            <div class="resumen-row total">
                <span class="label">Total</span>
                <span class="value">S/ @totalFinal.ToString("0.00")</span>
            </div>
            <p class="igv-note">Incluye IGV. Envío coordinado por WhatsApp.</p>

            <button class="btn-confirmar" onclick="document.getElementById('btnSubmit').click()">
                Confirmar pedido →
            </button>
            <a href="@Url.Action("Index", "Carrito")" class="btn-volver">← Editar carrito</a>
        </div>
    </div>

</body>
</html>