@model Sistema_BC_SMART_POINT.Models.Venta

@{
    ViewData["Title"] = $"Pedido #{Model.IdVenta} confirmado";
    decimal subtotal = Model.DetallesVenta.Sum(d => d.SubTotal);
    decimal igv = Math.Round(subtotal * 0.18m, 2);
    decimal total = subtotal + igv;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pedido confirmado – BC SMART POINT</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #F5F3EE;
            --surface: #fff;
            --ink: #1A1A18;
            --ink-2: #5C5C57;
            --ink-3: #9C9C96;
            --accent: #D85A30;
            --accent-light: #FAECE7;
            --accent-dark: #993C1D;
            --green: #3B6D11;
            --green-bg: #EAF3DE;
            --border: rgba(26,26,24,.10);
            --radius: 16px;
            --radius-sm: 10px;
            --fd: 'Syne',sans-serif;
            --fb: 'DM Sans',sans-serif;
        }

        body {
            background: var(--bg);
            color: var(--ink);
            font-family: var(--fb);
            font-size: 15px;
        }

        .site-header {
            background: var(--ink);
            padding: 1.25rem 2.5rem;
        }

        .brand {
            font-family: var(--fd);
            font-size: 1.1rem;
            font-weight: 800;
            color: #fff;
            text-decoration: none;
            letter-spacing: -.02em;
        }

            .brand span {
                color: var(--accent);
            }

        .page {
            max-width: 640px;
            margin: 3rem auto 5rem;
            padding: 0 1.5rem;
        }

        /* CHECK HERO */
        .check-hero {
            text-align: center;
            margin-bottom: 2.5rem;
            animation: popIn .4s cubic-bezier(.34,1.56,.64,1) both;
        }

        {
            opacity: 0;
            transform: scale(.6)
        }

        to {
            opacity: 1;
            transform: scale(1)
        }

        }

        .check-circle {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: var(--green-bg);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.25rem;
        }

            .check-circle svg {
                width: 32px;
                height: 32px;
            }

        .check-hero h1 {
            font-family: var(--fd);
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -.03em;
            margin-bottom: .4rem;
        }

        .check-hero p {
            font-size: .9rem;
            color: var(--ink-3);
        }

        .order-num {
            font-family: var(--fd);
            font-size: 1rem;
            font-weight: 800;
            color: var(--accent);
            margin-top: .5rem;
        }

        /* CARD */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            margin-bottom: 1.25rem;
        }

        .card-head {
            padding: .85rem 1.25rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .card-head h2 {
                font-family: var(--fd);
                font-size: .82rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: .06em;
                color: var(--ink-3);
            }

        /* DETALLE ITEMS */
        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: .75rem 1.25rem;
            border-bottom: 1px solid var(--border);
            font-size: .88rem;
            gap: .75rem;
        }

            .detail-row:last-child {
                border-bottom: none;
            }

        .dr-name {
            flex: 1;
            font-weight: 500;
        }

        .dr-qty {
            color: var(--ink-3);
            font-size: .8rem;
        }

        .dr-price {
            font-weight: 500;
            white-space: nowrap;
        }

        /* TOTALES */
        .total-row {
            display: flex;
            justify-content: space-between;
            padding: .5rem 1.25rem;
            font-size: .88rem;
        }

            .total-row .label {
                color: var(--ink-2);
            }

            .total-row.grand .label {
                font-weight: 700;
                color: var(--ink);
                font-size: .95rem;
            }

            .total-row.grand .value {
                font-family: var(--fd);
                font-size: 1.3rem;
                font-weight: 800;
                color: var(--accent);
            }

        .divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 0;
        }

        /* ENVÍO INFO */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
        }

        .info-cell {
            padding: .85rem 1.25rem;
            font-size: .85rem;
        }

            .info-cell:nth-child(odd) {
                border-right: 1px solid var(--border);
            }

            .info-cell .ic-label {
                font-size: .72rem;
                text-transform: uppercase;
                letter-spacing: .06em;
                color: var(--ink-3);
                margin-bottom: .25rem;
            }

            .info-cell .ic-val {
                font-weight: 500;
                color: var(--ink);
            }

        /* ACTIONS */
        .actions {
            display: flex;
            gap: .75rem;
            margin-top: 2rem;
        }

        .btn-primary {
            flex: 1;
            text-align: center;
            font-family: var(--fb);
            font-size: .9rem;
            font-weight: 500;
            background: var(--ink);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: .75rem;
            text-decoration: none;
            transition: background .15s;
            cursor: pointer;
        }

            .btn-primary:hover {
                background: #2e2e2b;
            }

        .btn-secondary {
            flex: 1;
            text-align: center;
            font-family: var(--fb);
            font-size: .9rem;
            font-weight: 500;
            background: none;
            color: var(--ink);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: .75rem;
            text-decoration: none;
            transition: all .15s;
        }

            .btn-secondary:hover {
                border-color: var(--ink);
            }

        {
            grid-template-columns: 1fr;
        }

        .info-cell:nth-child(odd) {
            border-right: none;
            border-bottom: 1px solid var(--border);
        }

        .actions {
            flex-direction: column;
        }

        }
    </style>
</head>
<body>

    <header class="site-header">
        <a href="@Url.Action("Index", "Catalogo")" class="brand">BC <span>SMART</span> POINT</a>
    </header>

    <div class="page">

        <!-- HERO CONFIRMACIÓN -->
        <div class="check-hero">
            <div class="check-circle">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 16l7 7L26 9" stroke="#3B6D11" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <h1>¡Pedido confirmado!</h1>
            <p>Gracias por tu compra. Te contactaremos para coordinar la entrega.</p>
            <div class="order-num">Pedido #@Model.IdVenta</div>
        </div>

        <!-- PRODUCTOS -->
        <div class="card">
            <div class="card-head">
                <h2>Productos</h2>
                <span style="font-size:.8rem;color:var(--ink-3)">@Model.DetallesVenta.Count ítem(s)</span>
            </div>
            @foreach (var d in Model.DetallesVenta)
            {
                <div class="detail-row">
                    <span class="dr-name">@d.Producto?.Nombre</span>
                    <span class="dr-qty">× @d.Cantidad</span>
                    <span class="dr-price">S/ @d.SubTotal.ToString("0.00")</span>
                </div>
            }
            <hr class="divider" />
            <div class="total-row">
                <span class="label">Subtotal</span>
                <span>S/ @subtotal.ToString("0.00")</span>
            </div>
            <div class="total-row">
                <span class="label">IGV (18%)</span>
                <span>S/ @igv.ToString("0.00")</span>
            </div>
            <div class="total-row grand">
                <span class="label">Total pagado</span>
                <span class="value">S/ @Model.TotalVenta.ToString("0.00")</span>
            </div>
        </div>

        <!-- ENVÍO -->
        @if (Model.Envio != null)
        {
            <div class="card">
                <div class="card-head"><h2>Información de envío</h2></div>
                <div class="info-grid">
                    <div class="info-cell">
                        <div class="ic-label">Dirección</div>
                        <div class="ic-val">@Model.Envio.DireccionEnvio</div>
                    </div>
                    <div class="info-cell">
                        <div class="ic-label">Ciudad</div>
                        <div class="ic-val">@Model.Envio.Ciudad</div>
                    </div>
                    <div class="info-cell">
                        <div class="ic-label">Método de pago</div>
                        <div class="ic-val">@Model.MetodoPago</div>
                    </div>
                </div>
            </div>
        }

        <!-- ACCIONES -->
        <div class="actions">
            <a href="@Url.Action("Index", "Catalogo")" class="btn-primary">Seguir comprando</a>
            <a href="@Url.Action("Index", "Catalogo")" class="btn-secondary">Ver catálogo</a>
        </div>

    </div>
</body>
</html>